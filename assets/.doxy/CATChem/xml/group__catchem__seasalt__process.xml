      <memberdef kind="function" id="group__catchem__seasalt__process_1gaf00a5baf0452c8cdf568fbf90eb335ac" prot="private" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>pure real(fp) function</type>
        <definition>pure real(fp) function seasaltscheme_geos12_mod::seasaltemissiongong</definition>
        <argsstring>(r, dr, w, scalefac, afac, bfac, rpow, exppow, wpow)</argsstring>
        <name>seasaltemissiongong</name>
        <qualifiedname>seasaltscheme_geos12_mod::seasaltemissiongong</qualifiedname>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>r</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>dr</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>w</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>scalefac</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>afac</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>bfac</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>rpow</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>exppow</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
          <defname>wpow</defname>
        </param>
        <briefdescription>
<para>Function to compute sea salt emissions following the Gong style parameterization. </para>
        </briefdescription>
        <detaileddescription>
<para>Functional form is from Gong 2003: <formula id="0">$dN/dr = scalefac * 1.373 * (w^wpow) * (r^-aFac) * (1+0.057*r^rpow) * 10^(exppow*exp(-bFac^2))$</formula> where r is the particle radius at 80% RH, dr is the size bin width at 80% RH, and w is the wind speed</para>
<para><blockquote><para><zwj/> </para>
</blockquote><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">r</parametername>
</parameternamelist>
<parameterdescription>
<para>Wet particle radius [um] </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">dr</parametername>
</parameternamelist>
<parameterdescription>
<para>Wet particle bin width [um] </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">w</parametername>
</parameternamelist>
<parameterdescription>
<para>Grid box mean wind speed [m s-1] (10-m or ustar wind) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">scalefac</parametername>
</parameternamelist>
<parameterdescription>
<para>scale factor </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
