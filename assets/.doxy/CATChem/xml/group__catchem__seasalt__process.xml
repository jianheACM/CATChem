        <argsstring>(fsstemis, sst, sstflag, rc)</argsstring>
        <name>jeaglesstcorrection</name>
        <qualifiedname>seasaltscheme_geos12_mod::jeaglesstcorrection</qualifiedname>
        <param>
          <type>real(fp), intent(inout)</type>
          <defname>fsstemis</defname>
        </param>
        <param>
          <type>real(fp), intent(in)</type>
