      ! Scheme parameters
{% for param_name, param_info in scheme.parameters.items() %}
      {{ param_info.type | default('real(fp)') }} :: {{ param_name }} = {{ param_info.default | default('0.0_fp') }}  ! {{ param_info.description | default('Parameter') }}
{% endfor %}

      ! Required meteorological fields
      integer :: n_required_met_fields = {{ scheme.required_met_fields | length }}
      character(len=32) :: required_met_fields({{ scheme.required_met_fields | length if scheme.required_met_fields else 1 }})

   contains
      procedure, public :: validate => validate_{{ scheme.name }}_config
      procedure, public :: finalize => finalize_{{ scheme.name }}_config
   end type {{ config.class_name }}Scheme{{ scheme.class_name }}Config

   ! {{ scheme.name }} scheme uses local variables only - no persistent state type needed

{% endfor %}

contains

   !> Validate {{ config.name }} configuration
   subroutine validate_{{ config.name }}_config(this, error_handler)
      class({{ config.class_name }}Config), intent(inout) :: this
      type(ErrorHandler), intent(inout) :: error_handler

      character(len=256) :: error_msg

      ! Validate time step bounds
      if (this%dt_min <= 0.0_fp) then
         call error_handler%set_error(ERROR_CONFIG, &
            "Minimum time step must be positive")
         return
      end if

      if (this%dt_max < this%dt_min) then
         call error_handler%set_error(ERROR_CONFIG, &
            "Maximum time step must be >= minimum time step")
         return
      end if

      ! Validate active scheme
{% for scheme in config.schemes %}
{% if loop.first %}
      if (trim(this%scheme) /= '{{ scheme.name }}' .and. &
{% else %}
          trim(this%scheme) /= '{{ scheme.name }}' .and. &
{% endif %}
{% if loop.last %}
          .true.) then
{% endif %}
{% endfor %}
         write(error_msg, '(A)') "Invalid scheme: " // trim(this%scheme)
         call error_handler%set_error(ERROR_CONFIG, error_msg)
         return
      end if

   end subroutine validate_{{ config.name }}_config

   !> Print configuration summary
   subroutine print_{{ config.name }}_config_summary(this)
      class({{ config.class_name }}Config), intent(in) :: this

      write(*, '(A)') "=== {{ config.class_name }} Process Configuration ==="
      write(*, '(A,A)') "  Active scheme: ", trim(this%scheme)
      write(*, '(A,I0)') "  Number of species: ", this%n_species
      write(*, '(A,F0.1,A)') "  Minimum time step: ", this%dt_min, " s"
      write(*, '(A,F0.1,A)') "  Maximum time step: ", this%dt_max, " s"
{% if config.has_size_bins %}
      write(*, '(A,I0)') "  Number of size bins: ", this%n_size_bins
      write(*, '(A,A)') "  Size type: ", trim(this%size_type)
{% endif %}
      write(*, '(A,L1)') "  Output diagnostics: ", this%output_diagnostics
      write(*, '(A)') "============================================="

   end subroutine print_{{ config.name }}_config_summary

      !> Finalize {{ config.name }} configuration
   subroutine finalize_{{ config.name }}_config(this)
      class({{ config.class_name }}Config), intent(inout) :: this

      ! Deallocate species names array
      if (allocated(this%species_names)) then
         deallocate(this%species_names)
      end if

   end subroutine finalize_{{ config.name }}_config

