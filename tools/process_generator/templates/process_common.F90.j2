   !> Validate {{ config.name }} configuration
   subroutine validate_{{ config.name }}_config(this, error_handler)
      class({{ config.class_name }}Config), intent(inout) :: this
      type(ErrorManagerType), intent(inout) :: error_handler

      character(len=256) :: error_msg
      integer :: rc

      ! Validate time step bounds
      if (this%dt_min <= 0.0_fp) then
         call error_handler%report_error(ERROR_INVALID_CONFIG, &
            "Minimum time step must be positive", rc)
         return
      end if

      if (this%dt_max < this%dt_min) then
         call error_handler%report_error(ERROR_INVALID_CONFIG, &
            "Maximum time step must be >= minimum time step", rc)
         return
      end if

      ! Validate active scheme(s)
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! Validate gas scheme
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'gas' %}
{% if loop.first %}
      if (trim(this%gas_scheme) /= '{{ scheme.name }}' .and. &
{% else %}
          trim(this%gas_scheme) /= '{{ scheme.name }}' .and. &
{% endif %}
{% endif %}
{% endfor %}
          .true.) then
         write(error_msg, '(A)') "Invalid gas scheme: " // trim(this%gas_scheme)
         call error_handler%report_error(ERROR_INVALID_CONFIG, error_msg, rc)
         return
      end if

      ! Validate aerosol scheme
{% set aero_schemes = [] %}
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'aero' %}
{% set _ = aero_schemes.append(scheme.name) %}
{% endif %}
{% endfor %}
{% if aero_schemes %}
      if ({% for scheme_name in aero_schemes %}{% if loop.first %}trim(this%aero_scheme) /= '{{ scheme_name }}'{% else %} .and. &
          trim(this%aero_scheme) /= '{{ scheme_name }}'{% endif %}{% endfor %} .and. &
          .true.) then
         write(error_msg, '(A)') "Invalid aerosol scheme: " // trim(this%aero_scheme)
         call error_handler%report_error(ERROR_INVALID_CONFIG, error_msg, rc)
         return
      end if
{% endif %}
{% else %}
      ! Validate scheme
{% for scheme in config.schemes %}
{% if loop.first %}
      if (trim(this%scheme) /= '{{ scheme.name }}' .and. &
{% else %}
          trim(this%scheme) /= '{{ scheme.name }}' .and. &
{% endif %}
{% if loop.last %}
          .true.) then
{% endif %}
{% endfor %}
         write(error_msg, '(A)') "Invalid scheme: " // trim(this%scheme)
         call error_handler%report_error(ERROR_INVALID_CONFIG, error_msg, rc)
         return
      end if
{% endif %}

   end subroutine validate_{{ config.name }}_config

   !> Print configuration summary
   subroutine print_{{ config.name }}_config_summary(this)
      class({{ config.class_name }}Config), intent(in) :: this

      write(*, '(A)') "=== {{ config.class_name }} Process Configuration ==="
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      write(*, '(A,A)') "  Gas scheme: ", trim(this%gas_scheme)
      write(*, '(A,A)') "  Aerosol scheme: ", trim(this%aero_scheme)
{% else %}
      write(*, '(A,A)') "  Active scheme: ", trim(this%scheme)
{% endif %}
      write(*, '(A,I0)') "  Number of species: ", this%n_species
      write(*, '(A,F0.1,A)') "  Minimum time step: ", this%dt_min, " s"
      write(*, '(A,F0.1,A)') "  Maximum time step: ", this%dt_max, " s"
{% if config.has_size_bins %}
      write(*, '(A,I0)') "  Number of size bins: ", this%n_size_bins
      write(*, '(A,A)') "  Size type: ", trim(this%size_type)
{% endif %}
      write(*, '(A,L1)') "  Output diagnostics: ", this%output_diagnostics
      write(*, '(A)') "============================================="

   end subroutine print_{{ config.name }}_config_summary

