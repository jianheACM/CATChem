   !> Convert integer to string (utility function)
   function int_to_string(int_val) result(str_val)
      integer, intent(in) :: int_val
      character(len=32) :: str_val

      write(str_val, '(I0)') int_val
      str_val = adjustl(str_val)

   end function int_to_string

   !> Load unified process configuration from ConfigManager
   !! This is the main function that ProcessInterface.parse_process_config should call
   !! Process reads its configuration directly from the master YAML via ConfigManager
   subroutine {{ config.name }}_process_load_config(this, config_data, error_handler)
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this
      type(ConfigDataType), intent(in) :: config_data
      type(ErrorManagerType), intent(inout) :: error_handler

      character(len=256) :: scheme_name
      integer :: ierr

      ! Process reads directly from master YAML structure: processes.{{ config.name }}.*
      ! ConfigManager provides generic YAML access, process handles its own configuration
      
      ! Load process metadata
      call config_data%get_string("processes/{{ config.name }}/name", this%process_name, ierr)
      if (ierr /= CC_SUCCESS) this%process_name = "{{ config.name }}"  ! default

      call config_data%get_string("processes/{{ config.name }}/version", this%process_version, ierr)
      if (ierr /= CC_SUCCESS) this%process_version = "1.0.0"  ! default

      call config_data%get_logical("processes/{{ config.name }}/activate", this%is_active, ierr)
      if (ierr /= CC_SUCCESS) this%is_active = .true.  ! default

      ! Load process-specific configuration directly from master YAML
      call config_data%get_string("processes/{{ config.name }}/scheme", this%{{ config.name }}_config%scheme, ierr)
      if (ierr /= CC_SUCCESS) then
         call error_handler%set_error(CC_FAILURE, &
            "Missing required 'scheme' in processes/{{ config.name }} configuration")
         return
      end if

{% if config.diagnostics %}
      ! Load diagnostic switch
      call config_data%get_logical("processes/{{ config.name }}/diagnostics", this%{{ config.name }}_config%diagnostics, ierr)
      if (ierr /= CC_SUCCESS) this%{{ config.name }}_config%diagnostics = .false.  ! Default
{% endif %}

      ! Species configuration is loaded from ChemState in load_species_from_chem_state
      ! The species come from the master species YAML file (CATChem_species.yml)
      ! and are filtered by is_{{ config.name }} property

{% if config.process_specific_params %}
      ! Load process-specific parameters from master YAML
{% for param_name, param_info in config.process_specific_params.items() %}
      call config_data%get_{{ param_info.yaml_type | default('real') }}("processes/{{ config.name }}/{{ param_name }}", &
           this%{{ config.name }}_config%{{ param_name }}, ierr)
      if (ierr /= CC_SUCCESS) this%{{ config.name }}_config%{{ param_name }} = {{ param_info.default }}
{% endfor %}
{% endif %}

      ! Load scheme-specific configuration from master YAML
      scheme_name = trim(this%{{ config.name }}_config%scheme)
      select case (scheme_name)
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         call this%load_{{ scheme.name }}_config(config_data, error_handler)
{% endfor %}
      case default
         call error_handler%set_error(CC_FAILURE, &
            "Unknown {{ config.name }} scheme: " // trim(scheme_name))
         return
      end select

   end subroutine {{ config.name }}_process_load_config

{% if config.species %}
   !> Load species from explicit list (from species_filter)
   !! This function is used when explicit species are provided via species_filter
   subroutine load_species_from_list(this, chem_state, error_handler)
      use ChemState_Mod, only: ChemStateType
      
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this
      type(ChemStateType), pointer, intent(in) :: chem_state
      type(ErrorManagerType), intent(inout) :: error_handler
      
      integer :: i, species_idx
      character(len=32) :: species_name
      logical :: found
      
      ! Explicit species list from configuration
      character(len=32), parameter :: EXPLICIT_SPECIES({{ config.species|length }}) = [ &
{% for species in config.species %}
         "{{ species }}"{{ ", &" if not loop.last else " ]" }}
{% endfor %}
      
      if (.not. associated(chem_state)) then
         call error_handler%set_error(CC_FAILURE, &
            "ChemState not associated in load_species_from_list")
         return
      end if
      
      ! Set number of species from explicit list
      this%{{ config.name }}_config%n_species = {{ config.species|length }}
      
      ! Deallocate existing arrays if allocated
      if (allocated(this%{{ config.name }}_config%species_names)) then
         deallocate(this%{{ config.name }}_config%species_names)
      end if
      if (allocated(this%{{ config.name }}_config%species_indices)) then
         deallocate(this%{{ config.name }}_config%species_indices)
      end if
{% if all_required_species_properties %}
{% for prop in all_required_species_properties %}
      if (allocated(this%{{ config.name }}_config%species_{{ prop }})) then
         deallocate(this%{{ config.name }}_config%species_{{ prop }})
      end if
{% endfor %}
{% endif %}
      
      ! Allocate arrays
      allocate(this%{{ config.name }}_config%species_names(this%{{ config.name }}_config%n_species))
      allocate(this%{{ config.name }}_config%species_indices(this%{{ config.name }}_config%n_species))
{% if all_required_species_properties %}
      
      ! Allocate species properties arrays
{% for prop in all_required_species_properties %}
      allocate(this%{{ config.name }}_config%species_{{ prop }}(this%{{ config.name }}_config%n_species))
{% endfor %}
{% endif %}
      
      ! Find indices for each explicit species
      do i = 1, this%{{ config.name }}_config%n_species
         species_name = trim(EXPLICIT_SPECIES(i))
         found = .false.
         
         ! Search for species in ChemState
         do species_idx = 1, size(chem_state%SpeciesNames)
            if (trim(chem_state%SpeciesNames(species_idx)) == species_name) then
               this%{{ config.name }}_config%species_names(i) = species_name
               this%{{ config.name }}_config%species_indices(i) = species_idx
               found = .true.
               exit
            end if
         end do
         
         if (.not. found) then
            call error_handler%set_error(CC_FAILURE, &
               "Species not found in ChemState: " // trim(species_name))
            return
         end if
      end do
      
{% if all_required_species_properties %}
      ! Load species properties from ChemState using found indices
      do i = 1, this%{{ config.name }}_config%n_species
         species_idx = this%{{ config.name }}_config%species_indices(i)
{% for prop in all_required_species_properties %}
         this%{{ config.name }}_config%species_{{ prop }}(i) = chem_state%ChemSpecies(species_idx)%{{ prop }}
{% endfor %}
      end do
{% endif %}
      
   end subroutine load_species_from_list
{% endif %}

{% if not config.species %}
   !> Load species from ChemState 
   !! This function is used for dynamic species discovery (by_metadata or all_species)
   !! For 'all_species' mode: loads all species using nSpecies and SpeciesIndex
   !! For 'by_metadata' mode: loads species by type using nSpecies{{ config.class_name }} and {{ config.class_name }}Index
   subroutine load_species_from_chem_state(this, chem_state, error_handler)
      use ChemState_Mod, only: ChemStateType
      
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this
      type(ChemStateType), pointer, intent(in) :: chem_state
      type(ErrorManagerType), intent(inout) :: error_handler
      
      integer :: i
      
      if (.not. associated(chem_state)) then
         call error_handler%set_error(CC_FAILURE, &
            "ChemState not associated in load_species_from_chem_state")
         return
      end if
      
{% if config.process_behavior and config.process_behavior.species_filter and config.process_behavior.species_filter.type == "all_species" %}
      ! all_species mode: Load all species from ChemState
      this%{{ config.name }}_config%n_species = chem_state%nSpecies
      
      if (this%{{ config.name }}_config%n_species <= 0) then
         call error_handler%set_error(CC_FAILURE, &
            "No species found in ChemState")
         return
      end if
      
      ! Check if SpeciesIndex is allocated and has correct size
      if (.not. allocated(chem_state%SpeciesIndex)) then
         call error_handler%set_error(CC_FAILURE, &
            "SpeciesIndex not allocated in ChemState")
         return
      end if
      
      if (size(chem_state%SpeciesIndex) < this%{{ config.name }}_config%n_species) then
         call error_handler%set_error(CC_FAILURE, &
            "SpeciesIndex size inconsistent with nSpecies")
         return
      end if
{% else %}
      ! by_metadata mode: Load species by type from ChemState using dynamic metadata flag mapping
{% if config.process_behavior and config.process_behavior.species_filter and config.process_behavior.species_filter.metadata_flags %}
{% set metadata_flag = config.process_behavior.species_filter.metadata_flags[0] %}
{% if metadata_flag.startswith('is_') %}
{% set flag_base = metadata_flag[3:] %}
{% else %}
{% set flag_base = metadata_flag %}
{% endif %}
{% if flag_base == 'seasalt' or flag_base == 'seaSalt' or flag_base == 'SeaSalt' %}
{% set species_type = 'SeaSalt' %}
{% elif flag_base == 'dust' or flag_base == 'Dust' %}
{% set species_type = 'Dust' %}
{% elif flag_base == 'gas' or flag_base == 'Gas' %}
{% set species_type = 'Gas' %}
{% elif flag_base == 'tracer' or flag_base == 'Tracer' %}
{% set species_type = 'Tracer' %}
{% elif flag_base == 'aerodrydep' or flag_base == 'aeroDryDep' or flag_base == 'AeroDryDep' %}
{% set species_type = 'AeroDryDep' %}
{% elif flag_base == 'drydep' or flag_base == 'dryDep' or flag_base == 'DryDep' %}
{% set species_type = 'DryDep' %}
{% else %}
{% set species_type = flag_base | capitalize %}
{% endif %}
      ! Dynamic mapping: {{ metadata_flag }} -> nSpecies{{ species_type }} and {{ species_type }}Index
      this%{{ config.name }}_config%n_species = chem_state%nSpecies{{ species_type }}
      
      if (this%{{ config.name }}_config%n_species <= 0) then
         call error_handler%set_error(CC_FAILURE, &
            "No {{ flag_base }} species found in ChemState")
         return
      end if
      
      ! Check if {{ species_type }}Index is allocated and has correct size
      if (.not. allocated(chem_state%{{ species_type }}Index)) then
         call error_handler%set_error(CC_FAILURE, &
            "{{ species_type }}Index not allocated in ChemState")
         return
      end if
      
      if (size(chem_state%{{ species_type }}Index) < this%{{ config.name }}_config%n_species) then
         call error_handler%set_error(CC_FAILURE, &
            "{{ species_type }}Index size inconsistent with nSpecies{{ species_type }}")
         return
      end if
{% else %}
      ! No metadata flags specified, use class-based indexing
      this%{{ config.name }}_config%n_species = chem_state%nSpecies{{ config.class_name }}
      
      if (this%{{ config.name }}_config%n_species <= 0) then
         call error_handler%set_error(CC_FAILURE, &
            "No {{ config.name }} species found in ChemState")
         return
      end if
      
      ! Check if {{ config.class_name }}Index is allocated and has correct size
      if (.not. allocated(chem_state%{{ config.class_name }}Index)) then
         call error_handler%set_error(CC_FAILURE, &
            "{{ config.class_name }}Index not allocated in ChemState")
         return
      end if
      
      if (size(chem_state%{{ config.class_name }}Index) < this%{{ config.name }}_config%n_species) then
         call error_handler%set_error(CC_FAILURE, &
            "{{ config.class_name }}Index size inconsistent with nSpecies{{ config.class_name }}")
         return
      end if
{% endif %}
{% endif %}
      
      ! Deallocate existing arrays if allocated
      if (allocated(this%{{ config.name }}_config%species_names)) then
         deallocate(this%{{ config.name }}_config%species_names)
      end if
      if (allocated(this%{{ config.name }}_config%species_indices)) then
         deallocate(this%{{ config.name }}_config%species_indices)
      end if
      
      ! Allocate arrays
      allocate(this%{{ config.name }}_config%species_names(this%{{ config.name }}_config%n_species))
      allocate(this%{{ config.name }}_config%species_indices(this%{{ config.name }}_config%n_species))
{% if all_required_species_properties %}
      
      ! Allocate species properties arrays
{% for prop in all_required_species_properties %}
      allocate(this%{{ config.name }}_config%species_{{ prop }}(this%{{ config.name }}_config%n_species))
{% endfor %}
{% endif %}
      
{% if config.process_behavior and config.process_behavior.species_filter and config.process_behavior.species_filter.type == "all_species" %}
      ! all_species mode: Copy all indices from SpeciesIndex
      this%{{ config.name }}_config%species_indices(1:this%{{ config.name }}_config%n_species) = &
         chem_state%SpeciesIndex(1:this%{{ config.name }}_config%n_species)
{% else %}
      ! by_metadata mode: Copy indices from metadata-specific index array using dynamic mapping
{% if config.process_behavior and config.process_behavior.species_filter and config.process_behavior.species_filter.metadata_flags %}
{% set metadata_flag = config.process_behavior.species_filter.metadata_flags[0] %}
{% if metadata_flag.startswith('is_') %}
{% set flag_base = metadata_flag[3:] %}
{% else %}
{% set flag_base = metadata_flag %}
{% endif %}
{% if flag_base == 'seasalt' or flag_base == 'seaSalt' or flag_base == 'SeaSalt' %}
{% set species_type = 'SeaSalt' %}
{% elif flag_base == 'dust' or flag_base == 'Dust' %}
{% set species_type = 'Dust' %}
{% elif flag_base == 'gas' or flag_base == 'Gas' %}
{% set species_type = 'Gas' %}
{% elif flag_base == 'tracer' or flag_base == 'Tracer' %}
{% set species_type = 'Tracer' %}
{% elif flag_base == 'aerodrydep' or flag_base == 'aeroDryDep' or flag_base == 'AeroDryDep' %}
{% set species_type = 'AeroDryDep' %}
{% elif flag_base == 'drydep' or flag_base == 'dryDep' or flag_base == 'DryDep' %}
{% set species_type = 'DryDep' %}
{% else %}
{% set species_type = flag_base | capitalize %}
{% endif %}
      ! Dynamic mapping: {{ metadata_flag }} -> {{ species_type }}Index
      this%{{ config.name }}_config%species_indices(1:this%{{ config.name }}_config%n_species) = &
         chem_state%{{ species_type }}Index(1:this%{{ config.name }}_config%n_species)
{% else %}
      ! No metadata flags specified, use class-based indexing
      this%{{ config.name }}_config%species_indices(1:this%{{ config.name }}_config%n_species) = &
         chem_state%{{ config.class_name }}Index(1:this%{{ config.name }}_config%n_species)
{% endif %}
{% endif %}
      
      ! Get species names using the indices
      do i = 1, this%{{ config.name }}_config%n_species
         if (this%{{ config.name }}_config%species_indices(i) > 0 .and. &
             this%{{ config.name }}_config%species_indices(i) <= size(chem_state%SpeciesNames)) then
            this%{{ config.name }}_config%species_names(i) = &
               trim(chem_state%SpeciesNames(this%{{ config.name }}_config%species_indices(i)))
         else
            call error_handler%set_error(CC_FAILURE, &
               "Invalid species index in species index array")
            return
         end if
      end do
      
{% if all_required_species_properties %}
      ! Load species properties from ChemState
      do i = 1, this%{{ config.name }}_config%n_species
         integer :: species_idx
         species_idx = this%{{ config.name }}_config%species_indices(i)
{% for prop in all_required_species_properties %}
         this%{{ config.name }}_config%species_{{ prop }}(i) = chem_state%ChemSpecies(species_idx)%{{ prop }}
{% endfor %}
      end do
{% endif %}
      
   end subroutine load_species_from_chem_state
{% endif %}

{% for scheme in config.schemes %}
   !> Load {{ scheme.name }} scheme configuration from master YAML
   subroutine load_{{ scheme.name }}_config(this, config_data, error_handler)
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this
      type(ConfigDataType), intent(in) :: config_data
      type(ErrorManagerType), intent(inout) :: error_handler

      integer :: ierr

      ! Load scheme parameters directly from processes/{{ config.name }}/{{ scheme.name }}/* in master YAML
{% for param_name, param_info in scheme.parameters.items() %}
{% set param_type = param_info.type | default('auto') %}
{% if param_type == 'auto' %}
{% if param_info.default is sameas true or param_info.default is sameas false %}
{% set yaml_type = 'logical' %}
{% else %}
{% set yaml_type = 'real' %}
{% endif %}
{% else %}
{% set yaml_type = param_info.yaml_type | default('real') %}
{% if param_type == 'logical' %}
{% set yaml_type = 'logical' %}
{% endif %}
{% endif %}
      call config_data%get_{{ yaml_type }}("processes/{{ config.name }}/{{ scheme.name }}/{{ param_name }}", &
           this%{{ scheme.name }}_config%{{ param_name }}, ierr)
      if (ierr /= CC_SUCCESS) this%{{ scheme.name }}_config%{{ param_name }} = {% if yaml_type == 'logical' %}{% if param_info.default %}{% if param_info.default is sameas true %}.true.{% else %}.false.{% endif %}{% else %}.false.{% endif %}{% else %}{{ param_info.default }}{% endif %}
{% endfor %}


   end subroutine load_{{ scheme.name }}_config

{% endfor %}

   !> Validate unified process configuration
   subroutine {{ config.name }}_process_validate(this, state_manager, error_handler)
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this
      type(StateManagerType), intent(in) :: state_manager
      type(ErrorManagerType), intent(inout) :: error_handler

      ! Validate main config
      call this%{{ config.name }}_config%validate(error_handler)
      if (error_handler%has_error()) return

      ! Validate scheme-specific config
      select case (trim(this%{{ config.name }}_config%scheme))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         call this%{{ scheme.name }}_config%validate(error_handler)
{% endfor %}
      end select

   end subroutine {{ config.name }}_process_validate

   !> Finalize unified process configuration
   subroutine {{ config.name }}_process_finalize(this)
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this

      call this%{{ config.name }}_config%finalize()
{% for scheme in config.schemes %}
      call this%{{ scheme.name }}_config%finalize()
{% endfor %}

   end subroutine {{ config.name }}_process_finalize

   !> Get active scheme configuration (polymorphic return)
   function get_active_scheme_config(this) result(scheme_config)
      class({{ config.class_name }}ProcessConfig), intent(in) :: this
      class(*), allocatable :: scheme_config

      select case (trim(this%{{ config.name }}_config%scheme))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         allocate(scheme_config, source=this%{{ scheme.name }}_config)
{% endfor %}
      case default
         ! Return null
      end select

   end function get_active_scheme_config

end module {{ config.class_name }}Common_Mod
