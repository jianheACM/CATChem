   !> Get active scheme configuration (polymorphic return)
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
   function get_active_scheme_config(this, gas_scheme) result(scheme_config)
{% else %}
   function get_active_scheme_config(this) result(scheme_config)
{% endif %}
      class({{ config.class_name }}ProcessConfig), intent(in) :: this
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      logical, optional, intent(in) :: gas_scheme  ! If true, return gas scheme; if false, return aerosol scheme
{% endif %}
      class(*), allocatable :: scheme_config

{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! For gas/aero differentiated processes, return requested scheme type
      if (present(gas_scheme) .and. gas_scheme) then
         ! Return gas scheme
         select case (trim(this%{{ config.name }}_config%gas_scheme))
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'gas' %}
         case ('{{ scheme.name }}')
            allocate(scheme_config, source=this%{{ scheme.name }}_config)
{% endif %}
{% endfor %}
         case default
            ! Return null
         end select
      else
         ! Return aerosol scheme (default or when gas_scheme = false)
         select case (trim(this%{{ config.name }}_config%aero_scheme))
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'aero' %}
         case ('{{ scheme.name }}')
            allocate(scheme_config, source=this%{{ scheme.name }}_config)
{% endif %}
{% endfor %}
         case default
            ! Return null
         end select
      end if
{% else %}
      select case (trim(this%{{ config.name }}_config%scheme))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         allocate(scheme_config, source=this%{{ scheme.name }}_config)
{% endfor %}
      case default
         ! Return null
      end select
{% endif %}

   end function get_active_scheme_config

   !> Map diagnostic species names to indices in the species_names array
   !! This function creates the diagnostic_species_id array that maps each diagnostic species
   !! to its corresponding index in the full species_names array
   subroutine map_diagnostic_species_indices(this, error_handler)
      class({{ config.class_name }}ProcessConfig), intent(inout) :: this
      type(ErrorManagerType), intent(inout) :: error_handler

      integer :: i, j, rc
      character(len=256) :: error_msg
      logical :: found_species

      ! Only proceed if diagnostic species are defined
      if (this%{{ config.name }}_config%n_diagnostic_species == 0) return

      ! Handle "All" case - map all available species
      if (this%{{ config.name }}_config%n_diagnostic_species == 1 .and. &
          trim(this%{{ config.name }}_config%diagnostic_species(1)) == "All") then
         
         ! Deallocate and reallocate for all species
         if (allocated(this%{{ config.name }}_config%diagnostic_species_id)) deallocate(this%{{ config.name }}_config%diagnostic_species_id)
         allocate(this%{{ config.name }}_config%diagnostic_species_id(this%{{ config.name }}_config%n_species))
         if (allocated(this%{{ config.name }}_config%diagnostic_species)) deallocate(this%{{ config.name }}_config%diagnostic_species)
         allocate(this%{{ config.name }}_config%diagnostic_species(this%{{ config.name }}_config%n_species))
         this%{{ config.name }}_config%n_diagnostic_species = this%{{ config.name }}_config%n_species
         this%{{ config.name }}_config%diagnostic_species = this%{{ config.name }}_config%species_names

         ! Map all species indices (1:n_species)
         do i = 1, this%{{ config.name }}_config%n_species
            this%{{ config.name }}_config%diagnostic_species_id(i) = i
         end do
         
         return
      end if

      ! Allocate diagnostic species indices array
      if (allocated(this%{{ config.name }}_config%diagnostic_species_id)) deallocate(this%{{ config.name }}_config%diagnostic_species_id)
      allocate(this%{{ config.name }}_config%diagnostic_species_id(this%{{ config.name }}_config%n_diagnostic_species))

      ! Map each diagnostic species name to its index in species_names
      do i = 1, this%{{ config.name }}_config%n_diagnostic_species
         found_species = .false.
         
         do j = 1, this%{{ config.name }}_config%n_species
            if (trim(this%{{ config.name }}_config%diagnostic_species(i)) == trim(this%{{ config.name }}_config%species_names(j))) then
               this%{{ config.name }}_config%diagnostic_species_id(i) = j
               found_species = .true.
               exit
            end if
         end do
         
         if (.not. found_species) then
            write(error_msg, '(A,A,A)') "Diagnostic species '", &
                  trim(this%{{ config.name }}_config%diagnostic_species(i)), &
                  "' not found in process species list"
            call error_handler%report_error(ERROR_NOT_FOUND, error_msg, rc)
            return
         end if
      end do

   end subroutine map_diagnostic_species_indices

end module {{ config.class_name }}Common_Mod
