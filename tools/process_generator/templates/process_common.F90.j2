!> \file {{ config.class_name }}Common_Mod.F90
!! \brief Common types and utilities for {{ config.name }} process
!!
!! This module defines the configuration and state types used by the
!! {{ config.name }} process and its schemes.
!!
!! Generated on: {{ timestamp }}
!! Author: {{ config.author }}
!! Version: {{ config.version }}

module {{ config.class_name }}Common_Mod

   use iso_fortran_env, only: fp => real64
   use ErrorHandler_Mod

   implicit none
   private

   ! Export types
   public :: {{ config.class_name }}Config
   public :: {{ config.class_name }}State
{% for scheme in config.schemes %}
   public :: {{ config.class_name }}Scheme{{ scheme.class_name }}Config
   public :: {{ config.class_name }}Scheme{{ scheme.class_name }}State
{% endfor %}

   ! Export utility functions
   public :: int_to_string

   !> Main configuration type for {{ config.name }} process
   type :: {{ config.class_name }}Config

      ! Process settings
      character(len=32) :: active_scheme = '{{ config.default_scheme }}'
      logical :: is_active = .true.
      real(fp) :: dt_min = 1.0_fp     ! Minimum time step (seconds)
      real(fp) :: dt_max = 3600.0_fp  ! Maximum time step (seconds)

      ! Species configuration
      integer :: n_species = {{ config.species | length if config.species else 0 }}
      character(len=32) :: species_names({{ config.species | length if config.species else 1 }})

{% if config.has_size_bins %}
      ! Size bin configuration
      integer :: n_size_bins = {{ config.size_bins.n_bins if config.size_bins else 0 }}
      character(len=16) :: size_type = '{{ config.size_bins.type if config.size_bins else "radius" }}'
      real(fp) :: size_bounds({{ (config.size_bins.n_bins + 1) if config.size_bins else 1 }})
{% endif %}

{% if config.is_multiphase %}
      ! Multiphase configuration
      integer :: n_phases = {{ config.phases | length }}
      character(len=16) :: phase_names({{ config.phases | length }})
{% endif %}

      ! Diagnostic configuration
      logical :: output_diagnostics = .true.
      real(fp) :: diagnostic_frequency = 3600.0_fp  ! Output frequency (seconds)

   contains
      procedure, public :: init => init_{{ config.name }}_config
      procedure, public :: validate => validate_{{ config.name }}_config
      procedure, public :: finalize => finalize_{{ config.name }}_config
      procedure, public :: print_summary => print_{{ config.name }}_config_summary
   end type {{ config.class_name }}Config

   !> Main state type for {{ config.name }} process
   type :: {{ config.class_name }}State

      ! Runtime state
      logical :: is_initialized = .false.
      real(fp) :: current_time = 0.0_fp
      real(fp) :: last_update_time = 0.0_fp
      integer :: n_columns = 0
      integer :: n_levels = 0

      ! Working arrays (allocated during initialization)
{% if config.process_type == "emission" %}
      real(fp), allocatable :: emission_rates(:,:)    ! (n_species, n_columns)
      real(fp), allocatable :: total_emissions(:)     ! (n_columns)
{% elif config.process_type == "chemistry" %}
      real(fp), allocatable :: reaction_rates(:,:)    ! (n_reactions, n_columns)
      real(fp), allocatable :: concentrations(:,:,:)  ! (n_species, n_levels, n_columns)
{% endif %}

      ! Diagnostic arrays
{% for diagnostic in config.diagnostics %}
      real(fp), allocatable :: {{ diagnostic.name | lower_snake }}(:)  ! {{ diagnostic.description }}
{% endfor %}

   contains
      procedure, public :: init => init_{{ config.name }}_state
      procedure, public :: allocate_arrays => allocate_{{ config.name }}_state_arrays
      procedure, public :: reset => reset_{{ config.name }}_state
      procedure, public :: finalize => finalize_{{ config.name }}_state
   end type {{ config.class_name }}State

{% for scheme in config.schemes %}
   !> Configuration type for {{ scheme.name }} scheme
   type :: {{ config.class_name }}Scheme{{ scheme.class_name }}Config

      ! Scheme metadata
      character(len=64) :: scheme_name = '{{ scheme.name }}'
      character(len=256) :: description = '{{ scheme.description }}'
      character(len=64) :: author = '{{ scheme.author }}'
      character(len=16) :: algorithm_type = '{{ scheme.algorithm_type }}'

      ! Scheme parameters
{% for param_name, param_info in scheme.parameters.items() %}
      {{ param_info.type | default('real(fp)') }} :: {{ param_name }} = {{ param_info.default | default('0.0_fp') }}  ! {{ param_info.description | default('Parameter') }}
{% endfor %}

      ! Required meteorological fields
      integer :: n_required_met_fields = {{ scheme.required_met_fields | length }}
      character(len=32) :: required_met_fields({{ scheme.required_met_fields | length if scheme.required_met_fields else 1 }})

   contains
      procedure, public :: init => init_{{ scheme.name }}_config
      procedure, public :: validate => validate_{{ scheme.name }}_config
      procedure, public :: finalize => finalize_{{ scheme.name }}_config
   end type {{ config.class_name }}Scheme{{ scheme.class_name }}Config

   !> State type for {{ scheme.name }} scheme
   type :: {{ config.class_name }}Scheme{{ scheme.class_name }}State

      ! Scheme working arrays
      real(fp), allocatable :: work_array_1(:,:)
      real(fp), allocatable :: work_array_2(:,:)

      ! Scheme-specific diagnostic arrays
{% for diagnostic in scheme.diagnostics %}
      real(fp), allocatable :: {{ diagnostic.name | lower_snake }}(:)  ! {{ diagnostic.description }}
{% endfor %}

   contains
      procedure, public :: init => init_{{ scheme.name }}_state
      procedure, public :: allocate_arrays => allocate_{{ scheme.name }}_state_arrays
      procedure, public :: reset => reset_{{ scheme.name }}_state
      procedure, public :: finalize => finalize_{{ scheme.name }}_state
   end type {{ config.class_name }}Scheme{{ scheme.class_name }}State

{% endfor %}

contains

   !> Initialize {{ config.name }} configuration
   subroutine init_{{ config.name }}_config(this, error_handler)
      class({{ config.class_name }}Config), intent(inout) :: this
      type(ErrorHandler), intent(inout) :: error_handler

      ! Set default species names
{% for species in config.species %}
      this%species_names({{ loop.index }}) = '{{ species }}'
{% endfor %}

{% if config.has_size_bins and config.size_bins %}
      ! Set default size bin bounds
{% for bound in config.size_bins.bounds %}
      this%size_bounds({{ loop.index }}) = {{ bound }}_fp
{% endfor %}
{% endif %}

{% if config.is_multiphase %}
      ! Set phase names
{% for phase in config.phases %}
      this%phase_names({{ loop.index }}) = '{{ phase }}'
{% endfor %}
{% endif %}

   end subroutine init_{{ config.name }}_config

   !> Validate {{ config.name }} configuration
   subroutine validate_{{ config.name }}_config(this, error_handler)
      class({{ config.class_name }}Config), intent(inout) :: this
      type(ErrorHandler), intent(inout) :: error_handler

      character(len=256) :: error_msg

      ! Validate time step bounds
      if (this%dt_min <= 0.0_fp) then
         call error_handler%set_error(ERROR_CONFIG, &
            "Minimum time step must be positive")
         return
      end if

      if (this%dt_max < this%dt_min) then
         call error_handler%set_error(ERROR_CONFIG, &
            "Maximum time step must be >= minimum time step")
         return
      end if

      ! Validate active scheme
{% for scheme in config.schemes %}
{% if loop.first %}
      if (trim(this%active_scheme) /= '{{ scheme.name }}' .and. &
{% else %}
          trim(this%active_scheme) /= '{{ scheme.name }}' .and. &
{% endif %}
{% if loop.last %}
          .true.) then
{% endif %}
{% endfor %}
         write(error_msg, '(A)') "Invalid scheme: " // trim(this%active_scheme)
         call error_handler%set_error(ERROR_CONFIG, error_msg)
         return
      end if

   end subroutine validate_{{ config.name }}_config

   !> Print configuration summary
   subroutine print_{{ config.name }}_config_summary(this)
      class({{ config.class_name }}Config), intent(in) :: this

      write(*, '(A)') "=== {{ config.class_name }} Process Configuration ==="
      write(*, '(A,A)') "  Active scheme: ", trim(this%active_scheme)
      write(*, '(A,I0)') "  Number of species: ", this%n_species
      write(*, '(A,F0.1,A)') "  Minimum time step: ", this%dt_min, " s"
      write(*, '(A,F0.1,A)') "  Maximum time step: ", this%dt_max, " s"
{% if config.has_size_bins %}
      write(*, '(A,I0)') "  Number of size bins: ", this%n_size_bins
      write(*, '(A,A)') "  Size type: ", trim(this%size_type)
{% endif %}
      write(*, '(A,L1)') "  Output diagnostics: ", this%output_diagnostics
      write(*, '(A)') "============================================="

   end subroutine print_{{ config.name }}_config_summary

   !> Finalize {{ config.name }} configuration
   subroutine finalize_{{ config.name }}_config(this)
      class({{ config.class_name }}Config), intent(inout) :: this

      ! Nothing to deallocate for basic configuration

   end subroutine finalize_{{ config.name }}_config

   !> Initialize {{ config.name }} state
   subroutine init_{{ config.name }}_state(this, n_columns, n_levels, error_handler)
      class({{ config.class_name }}State), intent(inout) :: this
      integer, intent(in) :: n_columns
      integer, intent(in) :: n_levels
      type(ErrorHandler), intent(inout) :: error_handler

      this%n_columns = n_columns
      this%n_levels = n_levels
      this%current_time = 0.0_fp
      this%last_update_time = 0.0_fp

      call this%allocate_arrays(error_handler)
      if (error_handler%has_error()) return

      this%is_initialized = .true.

   end subroutine init_{{ config.name }}_state

   !> Allocate state arrays
   subroutine allocate_{{ config.name }}_state_arrays(this, error_handler)
      class({{ config.class_name }}State), intent(inout) :: this
      type(ErrorHandler), intent(inout) :: error_handler

      integer :: alloc_stat

{% if config.process_type == "emission" %}
      ! Allocate emission arrays
      allocate(this%emission_rates({{ config.species | length if config.species else 1 }}, this%n_columns), &
               stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate emission_rates array")
         return
      end if

      allocate(this%total_emissions(this%n_columns), stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate total_emissions array")
         return
      end if
{% elif config.process_type == "chemistry" %}
      ! Allocate chemistry arrays
      allocate(this%concentrations({{ config.species | length if config.species else 1 }}, &
                                   this%n_levels, this%n_columns), &
               stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate concentrations array")
         return
      end if
{% endif %}

      ! Allocate diagnostic arrays
{% for diagnostic in config.diagnostics %}
      allocate(this%{{ diagnostic.name | lower_snake }}(this%n_columns), stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate {{ diagnostic.name | lower_snake }} array")
         return
      end if
{% endfor %}

   end subroutine allocate_{{ config.name }}_state_arrays

   !> Reset state arrays to zero
   subroutine reset_{{ config.name }}_state(this)
      class({{ config.class_name }}State), intent(inout) :: this

{% if config.process_type == "emission" %}
      if (allocated(this%emission_rates)) this%emission_rates = 0.0_fp
      if (allocated(this%total_emissions)) this%total_emissions = 0.0_fp
{% elif config.process_type == "chemistry" %}
      if (allocated(this%concentrations)) this%concentrations = 0.0_fp
{% endif %}

{% for diagnostic in config.diagnostics %}
      if (allocated(this%{{ diagnostic.name | lower_snake }})) this%{{ diagnostic.name | lower_snake }} = 0.0_fp
{% endfor %}

   end subroutine reset_{{ config.name }}_state

   !> Finalize {{ config.name }} state
   subroutine finalize_{{ config.name }}_state(this)
      class({{ config.class_name }}State), intent(inout) :: this

{% if config.process_type == "emission" %}
      if (allocated(this%emission_rates)) deallocate(this%emission_rates)
      if (allocated(this%total_emissions)) deallocate(this%total_emissions)
{% elif config.process_type == "chemistry" %}
      if (allocated(this%concentrations)) deallocate(this%concentrations)
{% endif %}

{% for diagnostic in config.diagnostics %}
      if (allocated(this%{{ diagnostic.name | lower_snake }})) deallocate(this%{{ diagnostic.name | lower_snake }})
{% endfor %}

      this%is_initialized = .false.

   end subroutine finalize_{{ config.name }}_state

{% for scheme in config.schemes %}
   !> Initialize {{ scheme.name }} scheme configuration
   subroutine init_{{ scheme.name }}_config(this, parent_config, error_handler)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}Config), intent(inout) :: this
      type({{ config.class_name }}Config), intent(in) :: parent_config
      type(ErrorHandler), intent(inout) :: error_handler

      ! Set required meteorological fields
{% for field in scheme.required_met_fields %}
      this%required_met_fields({{ loop.index }}) = '{{ field }}'
{% endfor %}

      ! Initialize scheme-specific parameters
      ! TODO: Load from configuration file or use defaults

   end subroutine init_{{ scheme.name }}_config

   !> Validate {{ scheme.name }} scheme configuration
   subroutine validate_{{ scheme.name }}_config(this, error_handler)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}Config), intent(inout) :: this
      type(ErrorHandler), intent(inout) :: error_handler

      ! TODO: Add scheme-specific validation

   end subroutine validate_{{ scheme.name }}_config

   !> Finalize {{ scheme.name }} scheme configuration
   subroutine finalize_{{ scheme.name }}_config(this)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}Config), intent(inout) :: this

      ! Nothing to deallocate for basic configuration

   end subroutine finalize_{{ scheme.name }}_config

   !> Initialize {{ scheme.name }} scheme state
   subroutine init_{{ scheme.name }}_state(this, parent_state, error_handler)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}State), intent(inout) :: this
      type({{ config.class_name }}State), intent(in) :: parent_state
      type(ErrorHandler), intent(inout) :: error_handler

      call this%allocate_arrays(parent_state%n_columns, error_handler)

   end subroutine init_{{ scheme.name }}_state

   !> Allocate {{ scheme.name }} scheme state arrays
   subroutine allocate_{{ scheme.name }}_state_arrays(this, n_columns, error_handler)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}State), intent(inout) :: this
      integer, intent(in) :: n_columns
      type(ErrorHandler), intent(inout) :: error_handler

      integer :: alloc_stat

      ! Allocate working arrays
      allocate(this%work_array_1({{ config.species | length if config.species else 1 }}, n_columns), &
               stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate {{ scheme.name }} work_array_1")
         return
      end if

      allocate(this%work_array_2({{ config.species | length if config.species else 1 }}, n_columns), &
               stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate {{ scheme.name }} work_array_2")
         return
      end if

      ! Allocate diagnostic arrays
{% for diagnostic in scheme.diagnostics %}
      allocate(this%{{ diagnostic.name | lower_snake }}(n_columns), stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate {{ scheme.name }} {{ diagnostic.name | lower_snake }} array")
         return
      end if
{% endfor %}

   end subroutine allocate_{{ scheme.name }}_state_arrays

   !> Reset {{ scheme.name }} scheme state
   subroutine reset_{{ scheme.name }}_state(this)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}State), intent(inout) :: this

      if (allocated(this%work_array_1)) this%work_array_1 = 0.0_fp
      if (allocated(this%work_array_2)) this%work_array_2 = 0.0_fp

{% for diagnostic in scheme.diagnostics %}
      if (allocated(this%{{ diagnostic.name | lower_snake }})) this%{{ diagnostic.name | lower_snake }} = 0.0_fp
{% endfor %}

   end subroutine reset_{{ scheme.name }}_state

   !> Finalize {{ scheme.name }} scheme state
   subroutine finalize_{{ scheme.name }}_state(this)
      class({{ config.class_name }}Scheme{{ scheme.class_name }}State), intent(inout) :: this

      if (allocated(this%work_array_1)) deallocate(this%work_array_1)
      if (allocated(this%work_array_2)) deallocate(this%work_array_2)

{% for diagnostic in scheme.diagnostics %}
      if (allocated(this%{{ diagnostic.name | lower_snake }})) deallocate(this%{{ diagnostic.name | lower_snake }})
{% endfor %}

   end subroutine finalize_{{ scheme.name }}_state

{% endfor %}

   !> Convert integer to string (utility function)
   function int_to_string(int_val) result(str_val)
      integer, intent(in) :: int_val
      character(len=32) :: str_val

      write(str_val, '(I0)') int_val
      str_val = adjustl(str_val)

   end function int_to_string

end module {{ config.class_name }}Common_Mod
