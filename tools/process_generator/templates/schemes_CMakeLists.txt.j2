# {{ config.class_name }} Schemes CMakeLists.txt
# Generated on: {{ timestamp }}

# This file is included by the parent CMakeLists.txt
# Schemes are built as part of the main process library

# Scheme source files are defined in the parent CMakeLists.txt:
{% for scheme in config.schemes %}
# - {{ config.class_name }}Scheme_{{ scheme.class_name }}_Mod.F90
{% endfor %}

# Scheme-specific configurations can be added here if needed

{% for scheme in config.schemes %}
# {{ scheme.class_name }} scheme configuration
{% if scheme.algorithm_type == "implicit" %}
# {{ scheme.class_name }} uses implicit algorithms - may need linear algebra libraries
{% endif %}
{% if scheme.required_met_fields %}
# Required meteorological fields for {{ scheme.class_name }}:
{% for field in scheme.required_met_fields %}
#   - {{ field }}
{% endfor %}
{% endif %}

{% endfor %}

# Scheme validation targets
{% for scheme in config.schemes %}
add_custom_target(validate_{{ scheme.name }}_scheme
    COMMAND ${CMAKE_COMMAND} -E echo "Validating {{ scheme.name }} scheme implementation"
    COMMENT "Validating {{ scheme.name }} scheme"
)
{% endfor %}

# Combined validation target
add_custom_target(validate_all_schemes
    DEPENDS
{% for scheme in config.schemes %}
        validate_{{ scheme.name }}_scheme
{% endfor %}
    COMMENT "Validating all {{ config.name }} schemes"
)
