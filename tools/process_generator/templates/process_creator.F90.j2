!> \file {{ config.class_name }}ProcessCreator_Mod.F90
!! \brief Factory for creating {{ config.name }} process instances
!!
!! This module provides the factory functions for creating {{ config.name }}
!! process instances following the CATChem Process Factory pattern.
!!
!! Generated on: {{ timestamp }}
!! Author: {{ config.author }}
!! Version: {{ config.version }}

module {{ config.class_name }}ProcessCreator_Mod

   use iso_fortran_env, only: fp => real64
   use ProcessInterface_Mod
   use Process{{ config.class_name }}Interface_Mod
   use ErrorHandler_Mod

   implicit none
   private

   public :: create_{{ config.name }}_process
   public :: get_{{ config.name }}_process_info

   ! Process metadata constants
   character(len=*), parameter :: PROCESS_NAME = '{{ config.name }}'
   character(len=*), parameter :: PROCESS_VERSION = '{{ config.version }}'
   character(len=*), parameter :: PROCESS_DESCRIPTION = '{{ config.description }}'
   character(len=*), parameter :: PROCESS_AUTHOR = '{{ config.author }}'

contains

   !> Create a new {{ config.name }} process instance
   !!
   !! This factory function creates and returns a new instance of the
   !! {{ config.name }} process. The process is not initialized - the caller
   !! must call the init() method with appropriate configuration.
   !!
   !! @param[out] process     Allocated process instance
   !! @param[inout] error_handler Error handling object
   function create_{{ config.name }}_process(error_handler) result(process)
      type(ErrorHandler), intent(inout) :: error_handler
      class(ProcessInterface), allocatable :: process

      type(Process{{ config.class_name }}Interface), allocatable :: {{ config.name }}_process
      integer :: alloc_stat

      ! Allocate the process instance
      allocate({{ config.name }}_process, stat=alloc_stat)
      if (alloc_stat /= 0) then
         call error_handler%set_error(ERROR_MEMORY, &
            "Failed to allocate {{ config.name }} process instance")
         return
      end if

      ! Move to polymorphic variable
      call move_alloc({{ config.name }}_process, process)

   end function create_{{ config.name }}_process

   !> Get information about the {{ config.name }} process
   !!
   !! This function returns metadata about the {{ config.name }} process
   !! including name, version, description, and capabilities.
   !!
   !! @param[out] info Process information structure
   subroutine get_{{ config.name }}_process_info(info)
      type(ProcessInfo), intent(out) :: info

      ! Basic information
      info%name = PROCESS_NAME
      info%version = PROCESS_VERSION
      info%description = PROCESS_DESCRIPTION
      info%author = PROCESS_AUTHOR

      ! Process characteristics
      info%process_type = '{{ config.process_type }}'
      info%is_multiphase = {{ config.is_multiphase | fortran_boolean }}
      info%has_size_bins = {{ config.has_size_bins | fortran_boolean }}
      info%supports_vectorization = {{ config.supports_vectorization | fortran_boolean }}

      ! Integration characteristics
      info%timestep_dependency = '{{ config.timestep_dependency }}'
      info%parallelization = '{{ config.parallelization }}'
      info%memory_requirements = '{{ config.memory_requirements }}'

      ! Species information
      info%n_species = {{ config.species | length if config.species else 0 }}
{% if config.species %}
      allocate(info%species_names(info%n_species))
{% for species in config.species %}
      info%species_names({{ loop.index }}) = '{{ species }}'
{% endfor %}
{% endif %}

{% if config.has_size_bins and config.size_bins %}
      ! Size bin information
      info%n_size_bins = {{ config.size_bins.n_bins }}
      info%size_type = '{{ config.size_bins.type }}'
{% endif %}

{% if config.is_multiphase %}
      ! Phase information
      info%n_phases = {{ config.phases | length }}
      allocate(info%phase_names(info%n_phases))
{% for phase in config.phases %}
      info%phase_names({{ loop.index }}) = '{{ phase }}'
{% endfor %}
{% endif %}

      ! Available schemes
      info%n_schemes = {{ config.schemes | length }}
      allocate(info%scheme_names(info%n_schemes))
      allocate(info%scheme_descriptions(info%n_schemes))
{% for scheme in config.schemes %}
      info%scheme_names({{ loop.index }}) = '{{ scheme.name }}'
      info%scheme_descriptions({{ loop.index }}) = '{{ scheme.description }}'
{% endfor %}
      info%default_scheme = '{{ config.default_scheme }}'

      ! Required meteorological fields
      info%n_required_met_fields = {{ config.required_met_fields | length }}
{% if config.required_met_fields %}
      allocate(info%required_met_fields(info%n_required_met_fields))
{% for field in config.required_met_fields %}
      info%required_met_fields({{ loop.index }}) = '{{ field }}'
{% endfor %}
{% endif %}

      ! Optional meteorological fields
      info%n_optional_met_fields = {{ config.optional_met_fields | length }}
{% if config.optional_met_fields %}
      allocate(info%optional_met_fields(info%n_optional_met_fields))
{% for field in config.optional_met_fields %}
      info%optional_met_fields({{ loop.index }}) = '{{ field }}'
{% endfor %}
{% endif %}

      ! Required chemical fields
      info%n_required_chem_fields = {{ config.required_chem_fields | length }}
{% if config.required_chem_fields %}
      allocate(info%required_chem_fields(info%n_required_chem_fields))
{% for field in config.required_chem_fields %}
      info%required_chem_fields({{ loop.index }}) = '{{ field }}'
{% endfor %}
{% endif %}

      ! Diagnostic information
      info%n_diagnostics = {{ config.diagnostics | length }}
{% if config.diagnostics %}
      allocate(info%diagnostic_names(info%n_diagnostics))
      allocate(info%diagnostic_descriptions(info%n_diagnostics))
      allocate(info%diagnostic_units(info%n_diagnostics))
{% for diagnostic in config.diagnostics %}
      info%diagnostic_names({{ loop.index }}) = '{{ diagnostic.name }}'
      info%diagnostic_descriptions({{ loop.index }}) = '{{ diagnostic.description }}'
      info%diagnostic_units({{ loop.index }}) = '{{ diagnostic.units }}'
{% endfor %}
{% endif %}

   end subroutine get_{{ config.name }}_process_info

   !> Check if {{ config.name }} process is compatible with host model
   !!
   !! This function checks whether the {{ config.name }} process is compatible
   !! with the host model configuration and requirements.
   !!
   !! @param[in] host_config Host model configuration
   !! @param[inout] error_handler Error handling object
   !! @return .true. if compatible, .false. otherwise
   function is_{{ config.name }}_compatible(host_config, error_handler) result(is_compatible)
      type(HostModelConfig), intent(in) :: host_config
      type(ErrorHandler), intent(inout) :: error_handler
      logical :: is_compatible

      is_compatible = .true.

      ! Check required species
{% if config.species %}
      ! Check if required species are available in host model
      do i = 1, {{ config.species | length }}
         if (.not. host_config%has_species('{{ config.species[0] if config.species else "NO_SPECIES" }}')) then
            call error_handler%set_warning(WARNING_COMPATIBILITY, &
               "Required species not available: {{ config.species[0] if config.species else "NO_SPECIES" }}")
            is_compatible = .false.
         end if
      end do
{% endif %}

      ! Check required meteorological fields
{% if config.required_met_fields %}
{% for field in config.required_met_fields %}
      if (.not. host_config%has_met_field('{{ field }}')) then
         call error_handler%set_warning(WARNING_COMPATIBILITY, &
            "Required meteorological field not available: {{ field }}")
         is_compatible = .false.
      end if
{% endfor %}
{% endif %}

{% if config.has_size_bins %}
      ! Check size bin compatibility
      if (host_config%n_size_bins /= {{ config.size_bins.n_bins if config.size_bins else 0 }}) then
         call error_handler%set_warning(WARNING_COMPATIBILITY, &
            "Size bin configuration mismatch")
         is_compatible = .false.
      end if
{% endif %}

{% if config.is_multiphase %}
      ! Check multiphase support
      if (.not. host_config%supports_multiphase) then
         call error_handler%set_warning(WARNING_COMPATIBILITY, &
            "Host model does not support multiphase chemistry")
         is_compatible = .false.
      end if
{% endif %}

   end function is_{{ config.name }}_compatible

   !> Validate {{ config.name }} process configuration
   !!
   !! This function validates the process configuration against the
   !! process requirements and constraints.
   !!
   !! @param[in] config_data Configuration data (YAML, namelist, etc.)
   !! @param[inout] error_handler Error handling object
   !! @return .true. if valid, .false. otherwise
   function validate_{{ config.name }}_config_data(config_data, error_handler) result(is_valid)
      character(len=*), intent(in) :: config_data
      type(ErrorHandler), intent(inout) :: error_handler
      logical :: is_valid

      ! TODO: Implement configuration validation
      ! This should parse the config_data and validate:
      ! - Scheme selection is valid
      ! - Parameters are within acceptable ranges
      ! - Required fields are present
      ! - No conflicting options

      is_valid = .true.

      ! Placeholder validation
      if (len_trim(config_data) == 0) then
         call error_handler%set_error(ERROR_CONFIG, &
            "Empty configuration data provided")
         is_valid = .false.
      end if

   end function validate_{{ config.name }}_config_data

   !> Get default configuration for {{ config.name }} process
   !!
   !! This function returns a default configuration string that can be
   !! used to initialize the {{ config.name }} process with reasonable defaults.
   !!
   !! @param[out] config_data Default configuration string
   subroutine get_{{ config.name }}_default_config(config_data)
      character(len=*), intent(out) :: config_data

      ! Return default YAML configuration
      config_data = &
         '# Default {{ config.name }} process configuration' // new_line('A') // &
         'process:' // new_line('A') // &
         '  name: "{{ config.name }}"' // new_line('A') // &
         '  version: "{{ config.version }}"' // new_line('A') // &
         '  active_scheme: "{{ config.default_scheme }}"' // new_line('A') // &
         '  is_active: true' // new_line('A') // &
         '' // new_line('A') // &
{% if config.schemes %}
         '# Scheme configuration' // new_line('A') // &
         'schemes:' // new_line('A') // &
{% for scheme in config.schemes %}
         '  {{ scheme.name }}:' // new_line('A') // &
         '    description: "{{ scheme.description }}"' // new_line('A') // &
         '    algorithm_type: "{{ scheme.algorithm_type }}"' // new_line('A') // &
{% if scheme.parameters %}
         '    parameters:' // new_line('A') // &
{% for param_name, param_info in scheme.parameters.items() %}
         '      {{ param_name }}: {{ param_info.default | default(0.0) }}' // new_line('A') // &
{% endfor %}
{% endif %}
{% if not loop.last %}
         '' // new_line('A') // &
{% endif %}
{% endfor %}
{% endif %}
         '' // new_line('A') // &
         '# Diagnostic configuration' // new_line('A') // &
         'diagnostics:' // new_line('A') // &
         '  output_frequency: 3600.0  # seconds' // new_line('A') // &
         '  output_diagnostics: true'

   end subroutine get_{{ config.name }}_default_config

end module {{ config.class_name }}ProcessCreator_Mod
