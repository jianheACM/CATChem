# Example configuration for {{ config.name }} process
# Generated on: {{ timestamp }}
# Author: {{ config.author }}

process:
  name: "{{ config.name }}"
  version: "{{ config.version }}"
  description: "{{ config.description }}"
  active_scheme: "{{ config.default_scheme }}"
  is_active: true

  # Time stepping configuration
  dt_min: 1.0      # Minimum time step (seconds)
  dt_max: 3600.0   # Maximum time step (seconds)

{% if config.species %}
# Species configuration
species:
{% for species in config.species %}
  - name: "{{ species }}"
    molecular_weight: 1.0  # g/mol (update with actual values)
    properties:
{% if config.process_type == "dust" %}
      is_dust: true
{% elif config.process_type == "seasalt" %}
      is_seasalt: true
{% else %}
      is_{{ config.process_type }}: true
{% endif %}
{% endfor %}
{% endif %}

{% if config.has_size_bins and config.size_bins %}
# Size bin configuration
size_bins:
  n_bins: {{ config.size_bins.n_bins }}
  type: "{{ config.size_bins.type }}"  # radius, diameter, or mass
  bounds: [{{ config.size_bins.bounds | join(', ') }}]  # {{ config.size_bins.type }} bounds
  units: "{{ config.size_bins.units | default('m') }}"
{% endif %}

{% if config.is_multiphase %}
# Multiphase configuration
phases:
{% for phase in config.phases %}
  - "{{ phase }}"
{% endfor %}
{% endif %}

# Scheme configurations
schemes:
{% for scheme in config.schemes %}
  {{ scheme.name }}:
    description: "{{ scheme.description }}"
    author: "{{ scheme.author }}"
    algorithm_type: "{{ scheme.algorithm_type }}"

    # Scheme-specific parameters
    parameters:
{% for param_name, param_info in scheme.parameters.items() %}
      {{ param_name }}: {{ param_info.default | default(1.0) }}  # {{ param_info.description | default('Parameter description') }}
{% endfor %}

    # Required meteorological fields for this scheme
    required_met_fields:
{% for field in scheme.required_met_fields %}
      - "{{ field }}"
{% endfor %}

    # Scheme-specific diagnostic configuration
    diagnostics:
{% for diagnostic in scheme.diagnostics %}
      {{ diagnostic.name }}:
        description: "{{ diagnostic.description }}"
        units: "{{ diagnostic.units }}"
        output: true
        frequency: 3600.0  # Output frequency in seconds
{% endfor %}

{% endfor %}

# Diagnostic configuration
diagnostics:
  # Global diagnostic settings
  output_frequency: 3600.0  # seconds
  output_diagnostics: true

  # Individual diagnostic controls
{% for diagnostic in config.diagnostics %}
  {{ diagnostic.name }}:
    description: "{{ diagnostic.description }}"
    units: "{{ diagnostic.units }}"
    output: true
{% endfor %}

{% if config.process_type == "emission" %}
  # Emission tendency diagnostics
  emission_tendencies:
    output: true
    frequency: 3600.0  # seconds
    per_species: true  # Output tendency for each species
{% endif %}

# Performance and optimization settings
performance:
  parallelization: "{{ config.parallelization }}"
  memory_optimization: "{{ config.memory_requirements }}"
  vectorization: {{ config.supports_vectorization | lower }}

{% if config.timestep_dependency != "independent" %}
  # Timestep control (for dependent processes)
  timestep_control:
    dependency: "{{ config.timestep_dependency }}"
    adaptive: {{ 'true' if config.timestep_dependency == 'adaptive' else 'false' }}
{% if config.timestep_dependency == "adaptive" %}
    tolerance: 1.0e-6
    max_substeps: 10
{% endif %}
{% endif %}

# Input/output configuration
io:
  # Input data sources
  input_data:
{% if config.process_type == "emission" %}
    emission_inventory: "/path/to/emission/inventory.nc"
    spatial_allocation: "/path/to/spatial/factors.nc"
    temporal_allocation: "/path/to/temporal/factors.nc"
{% elif config.process_type == "chemistry" %}
    reaction_rates: "/path/to/reaction/rates.nc"
    photolysis_rates: "/path/to/photolysis/rates.nc"
{% endif %}

  # Output configuration
  output_data:
    base_directory: "/path/to/output"
    file_prefix: "{{ config.name }}_"
    compression: true

# Quality control and validation
quality_control:
  enable_bounds_checking: true
  enable_conservation_checks: {{ 'true' if config.process_type == 'chemistry' else 'false' }}
  enable_mass_balance_checks: {{ 'true' if config.process_type == 'emission' else 'false' }}

  # Value limits
  limits:
{% if config.process_type == "emission" %}
    max_emission_rate: 1.0e-3  # kg/m²/s
    min_emission_rate: 0.0
{% elif config.process_type == "chemistry" %}
    max_concentration: 1.0e-6  # kg/kg
    min_concentration: 0.0
{% endif %}

# Debugging and logging
debug:
  level: "info"  # debug, info, warning, error
  output_file: "{{ config.name }}_debug.log"
  flush_frequency: 100  # Flush log every N time steps

  # Debug-specific outputs
  debug_outputs:
    intermediate_variables: false
    conservation_diagnostics: false
    timing_information: true
