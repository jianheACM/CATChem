   !> Initialize the {{ config.name }} process
   subroutine init_{{ config.name }}_process(this, state_manager, config_data, error_handler)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      character(len=*), intent(in) :: config_data
      type(ErrorHandler), intent(inout) :: error_handler

      character(len=256) :: error_msg
      integer :: i, rc

      ! Initialize parent
      call this%ProcessInterface%init(state_manager, config_data, error_handler)
      if (error_handler%has_error()) return

      ! Load and validate configuration
      call this%load_config(config_data, error_handler)
      if (error_handler%has_error()) return

      call this%validate_config(error_handler)
      if (error_handler%has_error()) return

      ! Set up species mapping
      call this%set_species_mapping(state_manager, error_handler)
      if (error_handler%has_error()) return

{% if config.has_size_bins %}
      ! Initialize size bins
      call this%init_size_bins(error_handler)
      if (error_handler%has_error()) return
{% endif %}

      ! Register diagnostics
      call this%register_diagnostics(state_manager, error_handler)
      if (error_handler%has_error()) return

      ! Initialize scheme-specific configurations and states
{% for scheme in config.schemes %}
      if (trim(this%active_scheme) == '{{ scheme.name }}') then
         allocate(this%config_{{ scheme.name }})
         allocate(this%state_{{ scheme.name }})
         call this%config_{{ scheme.name }}%init(this%config, error_handler)
         if (error_handler%has_error()) return
         call this%state_{{ scheme.name }}%init(this%state, error_handler)
         if (error_handler%has_error()) return
      end if
{% endfor %}

{% if config.process_type == "emission" %}
      ! Allocate emission tendencies
      allocate(this%emission_tendencies(this%n_species, state_manager%get_n_columns()))
      this%emission_tendencies = 0.0_fp
{% endif %}

      this%is_initialized = .true.

   end subroutine init_{{ config.name }}_process

   !> Run the {{ config.name }} process
   subroutine run_{{ config.name }}_process(this, state_manager, dt, error_handler)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      real(fp), intent(in) :: dt
      type(ErrorHandler), intent(inout) :: error_handler

      character(len=256) :: error_msg
      integer :: i_col, n_columns

      if (.not. this%is_initialized) then
         call error_handler%set_error(ERROR_PROCESS, &
            "{{ config.class_name }} process not initialized")
         return
      end if

      n_columns = state_manager%get_n_columns()

{% if config.process_type == "emission" %}
      ! Reset emission tendencies
      this%emission_tendencies = 0.0_fp
{% endif %}

      ! Process each column
      do i_col = 1, n_columns

         ! Run active scheme
{% for scheme in config.schemes %}
{% if loop.first %}
         if (trim(this%active_scheme) == '{{ scheme.name }}') then
{% else %}
         else if (trim(this%active_scheme) == '{{ scheme.name }}') then
{% endif %}
            call this%run_{{ scheme.name }}_scheme(state_manager, i_col, dt, error_handler)
            if (error_handler%has_error()) return
{% if loop.last %}
         else
            call error_handler%set_error(ERROR_PROCESS, &
               "Unknown {{ config.name }} scheme: " // trim(this%active_scheme))
            return
         end if
{% endif %}
{% endfor %}

      end do

{% if config.process_type == "emission" %}
      ! Apply emission tendencies to chemical state
      call this%apply_emission_tendencies(state_manager, dt, error_handler)
      if (error_handler%has_error()) return
{% endif %}

      ! Update diagnostics
      call this%update_diagnostics(state_manager, error_handler)
      if (error_handler%has_error()) return

   end subroutine run_{{ config.name }}_process

