   !> Set species mapping from chemical state
   subroutine set_{{ config.name }}_species_mapping(this, state_manager, error_handler)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      type(ErrorHandler), intent(inout) :: error_handler

      integer :: i, idx
      character(len=256) :: error_msg

      ! Map species names to indices in chemical state
      do i = 1, this%n_species
         idx = state_manager%get_species_index(this%species_names(i))
         if (idx <= 0) then
            write(error_msg, '(A)') "Species not found in chemical state: " // &
               trim(this%species_names(i))
            call error_handler%set_error(ERROR_SPECIES, error_msg)
            return
         end if
         this%species_indices(i) = idx
      end do

   end subroutine set_{{ config.name }}_species_mapping

   !> Register diagnostic fields
   subroutine register_{{ config.name }}_diagnostics(this, state_manager, error_handler)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      type(ErrorHandler), intent(inout) :: error_handler

      type(DiagnosticManager), pointer :: diag_mgr

      diag_mgr => state_manager%get_diagnostic_manager()

      ! Register common diagnostics
{% for diagnostic in config.diagnostics %}
      this%diag_{{ diagnostic.name | lower_snake }}_idx = diag_mgr%register_diagnostic( &
         name='{{ config.name }}_{{ diagnostic.name }}', &
         description='{{ diagnostic.description }}', &
         units='{{ diagnostic.units }}', &
         error_handler=error_handler)
      if (error_handler%has_error()) return
{% endfor %}

{% if config.process_type == "emission" %}
      ! Register emission tendency diagnostics for each species
      do i = 1, this%n_species
         write(name, '(A,A,A)') '{{ config.name }}_emission_', trim(this%species_names(i)), '_tendency'
         write(description, '(A,A)') 'Emission tendency for ', trim(this%species_names(i))
         idx = diag_mgr%register_diagnostic( &
            name=trim(name), &
            description=trim(description), &
            units='kg/m2/s', &
            error_handler=error_handler)
         if (error_handler%has_error()) return
      end do
{% endif %}

      ! Register scheme-specific diagnostics
{% for scheme in config.schemes %}
      if (trim(this%active_scheme) == '{{ scheme.name }}') then
{% for diagnostic in scheme.diagnostics %}
         this%diag_{{ scheme.name }}_{{ diagnostic.name | lower_snake }}_idx = diag_mgr%register_diagnostic( &
            name='{{ config.name }}_{{ scheme.name }}_{{ diagnostic.name }}', &
            description='{{ diagnostic.description }}', &
            units='{{ diagnostic.units }}', &
            error_handler=error_handler)
         if (error_handler%has_error()) return
{% endfor %}
      end if
{% endfor %}

   end subroutine register_{{ config.name }}_diagnostics

