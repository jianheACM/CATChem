{% for diagnostic in config.diagnostics %}
      ! - {{ diagnostic.name }} ({{ diagnostic.description }})
{% endfor %}
      if (this%process_config%{{ config.name }}_config%diagnostics) then
         ! Call with diagnostic outputs enabled
         call compute_{{ scheme.name }}( &
            n_levels, &
            n_species, &
            this%process_config%{{ scheme.name }}_config{% if scheme.required_met_fields and scheme.required_met_fields|length > 0 %}, &
{% for field in scheme.required_met_fields %}
{% if field is string %}
            {{ field | lower | replace('-', '_') | replace('.', '_') }}, &
{% else %}
            {{ field.variable_name }}, &
{% endif %}
{% endfor %}{% endif %}{% if scheme.required_species_properties and scheme.required_species_properties|length > 0 %}
{% for prop in scheme.required_species_properties %}
            species_{{ prop }}, &
{% endfor %}{% endif %}
            species_conc, &
            species_tendencies{% if config.diagnostics or scheme.scheme_diagnostics %}, &
{% for diagnostic in config.diagnostics %}
            this%column_{{ diagnostic.name }}, &
{% endfor %}{% for diagnostic in scheme.scheme_diagnostics %}
            this%column_{{ diagnostic.name }}{% if not loop.last %}, &
{% else %} &
{% endif %}
{% endfor %}{% endif %}
         )
      else
         ! Call without diagnostic outputs (optional parameters not passed)
         call compute_{{ scheme.name }}( &
            n_levels, &
            n_species, &
            this%process_config%{{ scheme.name }}_config{% if scheme.required_met_fields and scheme.required_met_fields|length > 0 %}, &
{% for field in scheme.required_met_fields %}
{% if field is string %}
            {{ field | lower | replace('-', '_') | replace('.', '_') }}, &
{% else %}
            {{ field.variable_name }}, &
{% endif %}
{% endfor %}{% endif %}{% if scheme.required_species_properties and scheme.required_species_properties|length > 0 %}
{% for prop in scheme.required_species_properties %}
            species_{{ prop }}, &
{% endfor %}{% endif %}
            species_conc, &
            species_tendencies &
         )
      end if

      ! Apply tendencies back to virtual column
      {% if scheme.affects_full_column %}
      ! Full column processing - apply tendencies to all levels
      do k = 1, n_levels
         do i = 1, n_species
            call column%set_chem_field(k, species_indices(i), &
                                      species_conc(k, i) + species_tendencies(k, i))
         end do
      end do
      {% else %}
      ! Surface-only processing - apply tendencies to surface level only
      do i = 1, n_species
         call column%set_chem_field(1, species_indices(i), &
                                   species_conc(1, i) + species_tendencies(1, i))
      end do
      {% endif %}

   end subroutine run_{{ scheme.name }}_scheme_column

{% endfor %}

{% else %}
   !> Run the active scheme (delegation pattern using unified configuration)
   subroutine run_active_scheme(this, state_manager, i_col, error_manager)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      integer, intent(in) :: i_col
      type(ErrorManagerType), intent(inout) :: error_manager

      ! Check if process is active
      if (.not. this%process_config%is_active) return

      ! Delegate to appropriate scheme using unified config
      select case (trim(this%process_config%{{ config.name }}_config%scheme))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         call this%run_{{ scheme.name }}_scheme(state_manager, i_col, error_manager)
{% endfor %}
      case default
         call error_manager%set_error(CC_FAILURE, &
            "Unknown {{ config.name }} scheme: " // trim(this%process_config%{{ config.name }}_config%scheme))
      end select

   end subroutine run_active_scheme

{% for scheme in config.schemes %}
   !> Run the {{ scheme.name }} scheme using unified configuration
   subroutine run_{{ scheme.name }}_scheme(this, state_manager, i_col, error_manager)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      integer, intent(in) :: i_col
      type(ErrorManagerType), intent(inout) :: error_manager

      ! TODO: Implement 3D processing version of scheme
      ! This would be similar to column version but work directly with StateManager

   end subroutine run_{{ scheme.name }}_scheme

{% endfor %}
{% endif %}

   !> Get required meteorological fields for this process
   function get_required_met_fields(this) result(field_names)
      class(Process{{ config.class_name }}Interface), intent(in) :: this
      character(len=64), allocatable :: field_names(:)

      ! Get scheme-specific fields based on selected scheme
      select case (trim(this%process_config%{{ config.name }}_config%scheme))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
{% if scheme.required_met_fields %}
         allocate(field_names({{ scheme.required_met_fields | length }}))
{% for field in scheme.required_met_fields %}
{% if field is string %}
         field_names({{ loop.index }}) = '{{ field }}'
{% else %}
         field_names({{ loop.index }}) = '{{ field.name }}'
{% endif %}
{% endfor %}
{% else %}
         allocate(field_names(0))
{% endif %}
{% endfor %}
      case default
         allocate(field_names(0))
      end select

   end function get_required_met_fields

   !> Get required diagnostic fields for this process
   function get_required_diagnostic_fields(this) result(field_names)
      class(Process{{ config.class_name }}Interface), intent(in) :: this
      character(len=64), allocatable :: field_names(:)

{% if config.diagnostics %}
      allocate(field_names({{ config.diagnostics | length }}))
{% for diagnostic in config.diagnostics %}
      field_names({{ loop.index }}) = '{{ diagnostic.name }}'
{% endfor %}
{% else %}
