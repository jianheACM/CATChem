            do j = 1, n_species_mapping(i)  ! Loop over chemical species mapped to this emission species
{% if config.process_behavior and config.process_behavior.tendency_mode == "multiplicative" %}
               ! Multiplicative tendency: new_conc = conc * (1 - loss_fraction)
               ! where loss_fraction = 1 - exp(-tendency * dt)
               loss_fraction = MAX(1.0_fp - exp(-species_tendencies(k, i) * this%get_timestep()), 0.0_fp)
               call column%set_chem_field(k, chem_species_indices(chem_idx), &
