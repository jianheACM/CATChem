   !> Get required meteorological fields
   function get_{{ config.name }}_required_met_fields(this) result(field_names)
      class(Process{{ config.class_name }}Interface), intent(in) :: this
      character(len=32), allocatable :: field_names(:)

      character(len=32) :: common_fields({{ config.required_met_fields | length }})
      character(len=32), allocatable :: scheme_fields(:)
      integer :: n_common, n_scheme, n_total

      ! Common required fields
{% for field in config.required_met_fields %}
      common_fields({{ loop.index }}) = '{{ field }}'
{% endfor %}
      n_common = {{ config.required_met_fields | length }}

      ! Scheme-specific fields
{% for scheme in config.schemes %}
{% if loop.first %}
      if (trim(this%active_scheme) == '{{ scheme.name }}') then
{% else %}
      else if (trim(this%active_scheme) == '{{ scheme.name }}') then
{% endif %}
         allocate(scheme_fields({{ scheme.required_met_fields | length }}))
{% for field in scheme.required_met_fields %}
         scheme_fields({{ loop.index }}) = '{{ field }}'
{% endfor %}
         n_scheme = {{ scheme.required_met_fields | length }}
{% if loop.last %}
      else
         allocate(scheme_fields(0))
         n_scheme = 0
      end if
{% endif %}
{% endfor %}

      ! Combine fields (TODO: remove duplicates)
      n_total = n_common + n_scheme
      allocate(field_names(n_total))
      field_names(1:n_common) = common_fields
      if (n_scheme > 0) then
         field_names(n_common+1:n_total) = scheme_fields
      end if

   end function get_{{ config.name }}_required_met_fields

{% if config.process_type == "emission" %}
   !> Apply emission tendencies to chemical state
   subroutine apply_{{ config.name }}_emission_tendencies(this, state_manager, dt, error_handler)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      real(fp), intent(in) :: dt
      type(ErrorHandler), intent(inout) :: error_handler

      real(fp), pointer :: chem_state(:,:,:)  ! (n_species, n_levels, n_columns)
      integer :: i, i_spec, n_levels, n_columns

      ! Get chemical state
      chem_state => state_manager%get_chem_state()
      n_levels = state_manager%get_n_levels()
      n_columns = state_manager%get_n_columns()

      ! Apply emission tendencies to surface level
      do i = 1, this%n_species
         i_spec = this%species_indices(i)
         chem_state(i_spec, 1, :) = chem_state(i_spec, 1, :) + &
            this%emission_tendencies(i, :) * dt
      end do

   end subroutine apply_{{ config.name }}_emission_tendencies
{% endif %}

   !> Finalize the {{ config.name }} process
   subroutine finalize_{{ config.name }}_process(this, error_handler)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(ErrorHandler), intent(inout) :: error_handler

      ! Deallocate arrays
      if (allocated(this%species_names)) deallocate(this%species_names)
      if (allocated(this%species_indices)) deallocate(this%species_indices)
{% if config.has_size_bins %}
      if (allocated(this%size_bin_bounds)) deallocate(this%size_bin_bounds)
      if (allocated(this%size_bin_centers)) deallocate(this%size_bin_centers)
{% endif %}
{% if config.process_type == "emission" %}
      if (allocated(this%emission_tendencies)) deallocate(this%emission_tendencies)
{% endif %}

      ! Deallocate configuration and state
      if (associated(this%config)) then
         call this%config%finalize()
         deallocate(this%config)
      end if
      if (associated(this%state)) then
         call this%state%finalize()
         deallocate(this%state)
      end if

      ! Finalize scheme configurations and states
{% for scheme in config.schemes %}
      if (allocated(this%config_{{ scheme.name }})) then
         call this%config_{{ scheme.name }}%finalize()
         deallocate(this%config_{{ scheme.name }})
      end if
      if (allocated(this%state_{{ scheme.name }})) then
         call this%state_{{ scheme.name }}%finalize()
         deallocate(this%state_{{ scheme.name }})
      end if
{% endfor %}

      this%is_initialized = .false.

   end subroutine finalize_{{ config.name }}_process

end module Process{{ config.class_name }}Interface_Mod
