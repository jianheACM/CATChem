{% endif %}

   end function get_required_diagnostic_fields

{% if config.diagnostics %}
   !> Register diagnostic fields with the DiagnosticManager

   subroutine register_process_diagnostics(this, container, rc)
      use DiagnosticInterface_Mod, only: DiagnosticRegistryType, DIAG_REAL_2D, DIAG_REAL_3D
      
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: container
      integer, intent(out) :: rc
      
      type(DiagnosticManagerType), pointer :: diag_mgr
      type(DiagnosticRegistryType), pointer :: registry
      type(GridManagerType), pointer :: grid_mgr
      character(len=32) :: selected_scheme
{% set required_dims = config | analyze_required_dimensions %}
      integer :: nx, ny{% if required_dims.dims_3d_species %}, n_species{% endif %}{% if required_dims.dims_3d_levels %}, nz{% endif %}
{% if required_dims.dims_2d %}
      integer :: dims_2d(2)
{% endif %}
{% if required_dims.dims_3d_species %}
      integer :: dims_3d_species(3)
{% endif %}
{% if required_dims.dims_3d_levels %}
      integer :: dims_3d_levels(3)
{% endif %}
      
      rc = CC_SUCCESS
      
      ! Only register diagnostics if enabled in config
      if (.not. this%process_config%{{ config.name }}_config%diagnostics) then
         return
      endif
      
      ! Get managers
      diag_mgr => container%get_diagnostic_manager()
      grid_mgr => container%get_grid_manager()
      
      ! Register this process with diagnostic manager (only once per process)
      call diag_mgr%register_process('{{ config.name }}', container, rc)
      if (rc /= CC_SUCCESS) return
      
      ! Get the process registry for registering individual diagnostics
      call diag_mgr%get_process_registry('{{ config.name }}', registry, rc)
      if (rc /= CC_SUCCESS) return
      
      ! Get grid dimensions
      nx = grid_mgr%geometry%get_nx()
      ny = grid_mgr%geometry%get_ny()
{% if required_dims.dims_3d_levels %}
      nz = grid_mgr%geometry%get_nz()
{% endif %}
{% if required_dims.dims_2d %}
      dims_2d = [nx, ny]
{% endif %}
      
{% if required_dims.dims_3d_species %}
      ! Get species count for 3D diagnostics
      n_species = this%process_config%{{ config.name }}_config%n_species
      dims_3d_species = [nx, ny, n_species]
{% endif %}
{% if required_dims.dims_3d_levels %}
      dims_3d_levels = [nx, ny, nz]
{% endif %}
      
{% for diagnostic in config.diagnostics %}
      ! Register {{ diagnostic.name }}
{% set diag_props = diagnostic | infer_diagnostic_properties(config) %}
      call this%register_diagnostic_field(registry, '{{ diagnostic.name }}', &
                                          '{{ diagnostic.description }}', &
                                          '{{ diagnostic.units }}', {{ diag_props.data_type }}, &
                                          '{{ config.name }}', {{ diag_props.fortran_dims }}, rc)
      if (rc /= CC_SUCCESS) return
      
{% endfor %}
      ! Get selected scheme
      selected_scheme = trim(this%process_config%{{ config.name }}_config%scheme)
      
      ! Register scheme-specific diagnostics based on selected scheme
      select case (selected_scheme)
      
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         ! Register {{ scheme.name }}-specific diagnostics
{% for diagnostic in scheme.scheme_diagnostics %}
{% set diag_props = diagnostic | infer_diagnostic_properties(config, scheme) %}
         call this%register_diagnostic_field(registry, '{{ diagnostic.name }}', &
                                             '{{ diagnostic.description }}', &
                                             '{{ diagnostic.units }}', {{ diag_props.data_type }}, &
                                             '{{ config.name }}', {{ diag_props.fortran_dims }}, rc)
         if (rc /= CC_SUCCESS) return
         
{% endfor %}
{% endfor %}
      case default
         ! Unknown scheme - only register common diagnostics
         ! (already done above)
         
      end select

   end subroutine register_process_diagnostics

   !> Calculate and update all diagnostic fields for this process
   !! 
   !! With the new flexible column-level design, diagnostics are calculated directly by the 
   !! science schemes for each column and passed to this method for aggregation or output.
   !! This approach uses dimension inference to reduce 2D->scalar and 3D->1D for column processing.
   subroutine calculate_and_update_diagnostics(this, column, rc)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(VirtualColumnType), intent(in) :: column
      integer, intent(out) :: rc
      
      integer :: i_col, j_col  ! Column grid position
{% if config.schemes and config.schemes[0].scheme_diagnostics %}
      character(len=64) :: selected_scheme
{% endif %}
      
      rc = CC_SUCCESS
      
      ! Skip if diagnostics not enabled
      if (.not. this%process_config%{{ config.name }}_config%diagnostics) return
      
      ! Get column grid position (x, y indices)
      i_col = column%get_i_index()
      j_col = column%get_j_index()
      
{% if config.diagnostics %}
      ! Update common diagnostic fields (used by all schemes)
{% for diagnostic in config.diagnostics %}
{% if ('per_level' in diagnostic.name or 'level' in diagnostic.name) and ('per_bin' in diagnostic.name or 'bin' in diagnostic.name) %}
      ! 2D diagnostic field
      call this%update_column_diagnostics('{{ diagnostic.name }}', &
                                          this%column_{{ diagnostic.name }}, &
                                          i_col, j_col, rc)
      if (rc /= CC_SUCCESS) return
{% elif 'per_level' in diagnostic.name or 'level' in diagnostic.name or 'per_bin' in diagnostic.name or 'bin' in diagnostic.name %}
      ! 1D diagnostic field
      call this%update_column_diagnostics('{{ diagnostic.name }}', &
                                          this%column_{{ diagnostic.name }}, &
                                          i_col, j_col, rc)
      if (rc /= CC_SUCCESS) return
{% else %}
      ! Scalar diagnostic field
      call this%update_column_diagnostics('{{ diagnostic.name }}', &
                                          this%column_{{ diagnostic.name }}, &
                                          i_col, j_col, rc)
      if (rc /= CC_SUCCESS) return
{% endif %}
      
{% endfor %}
{% endif %}
{% if config.schemes and config.schemes[0].scheme_diagnostics %}
      ! Update scheme-specific diagnostic fields based on active scheme
      selected_scheme = trim(this%process_config%{{ config.name }}_config%scheme)
      
      select case (selected_scheme)
{% for scheme in config.schemes %}
{% if scheme.scheme_diagnostics %}
      case ("{{ scheme.name }}")
{% for diagnostic in scheme.scheme_diagnostics %}
{% if ('per_level' in diagnostic.name or 'level' in diagnostic.name) and ('per_bin' in diagnostic.name or 'bin' in diagnostic.name) %}
         ! Update 2D level-species diagnostics (map to 4D global fields)
         if (allocated(this%column_{{ diagnostic.name }})) then
            call this%update_column_diagnostics('{{ diagnostic.name }}', &
                                                this%column_{{ diagnostic.name }}, &
                                                i_col, j_col, rc)
            if (rc /= CC_SUCCESS) return
         end if
{% elif 'per_level' in diagnostic.name or 'level' in diagnostic.name or 'per_bin' in diagnostic.name or 'bin' in diagnostic.name %}
         ! Update 1D diagnostics (map to 3D global fields)
         if (allocated(this%column_{{ diagnostic.name }})) then
            call this%update_column_diagnostics('{{ diagnostic.name }}', &
                                                this%column_{{ diagnostic.name }}, &
                                                i_col, j_col, rc)
            if (rc /= CC_SUCCESS) return
         end if
{% else %}
         ! Update scalar diagnostics (map to 2D global fields)
         if (allocated(this%column_{{ diagnostic.name }})) then
            call this%update_column_diagnostics('{{ diagnostic.name }}', &
                                                this%column_{{ diagnostic.name }}, &
                                                i_col, j_col, rc)
            if (rc /= CC_SUCCESS) return
         end if
{% endif %}
         
{% endfor %}
{% endif %}
{% endfor %}
      end select
{% endif %}
      
   end subroutine calculate_and_update_diagnostics

{% endif %}

end module Process{{ config.class_name }}Interface_Mod
