   !> Run the active scheme (delegation pattern using unified configuration)
   subroutine run_active_scheme(this, state_manager, i_col, error_manager)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      type(StateManagerType), intent(inout) :: state_manager
      integer, intent(in) :: i_col
      type(ErrorManagerType), intent(inout) :: error_manager

      ! Check if process is active
      if (.not. this%process_config%is_active) return

      ! Delegate to appropriate scheme using unified config
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! For gas/aerosol differentiated processing, run schemes based on species type
      ! Run gas scheme for gas species
      select case (trim(this%process_config%{{ config.name }}_config%gas_scheme))
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'gas' %}
      case ('{{ scheme.name }}')
         call this%run_{{ scheme.name }}_scheme(state_manager, i_col, error_manager)
{% endif %}
{% endfor %}
      case default
         call error_manager%set_error(CC_FAILURE, &
            "Unknown {{ config.name }} gas scheme: " // trim(this%process_config%{{ config.name }}_config%gas_scheme))
         return
      end select

      ! Run aerosol scheme for aerosol species
      select case (trim(this%process_config%{{ config.name }}_config%aero_scheme))
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'aero' %}
      case ('{{ scheme.name }}')
         call this%run_{{ scheme.name }}_scheme(state_manager, i_col, error_manager)
{% endif %}
{% endfor %}
      case default
         call error_manager%set_error(CC_FAILURE, &
            "Unknown {{ config.name }} aerosol scheme: " // trim(this%process_config%{{ config.name }}_config%aero_scheme))
      end select
{% else %}
      select case (trim(this%process_config%{{ config.name }}_config%scheme))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         call this%run_{{ scheme.name }}_scheme(state_manager, i_col, error_manager)
{% endfor %}
      case default
         call error_manager%set_error(CC_FAILURE, &
            "Unknown {{ config.name }} scheme: " // trim(this%process_config%{{ config.name }}_config%scheme))
      end select
{% endif %}

   end subroutine run_active_scheme

