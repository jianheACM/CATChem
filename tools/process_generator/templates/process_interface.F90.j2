   !> Set the active scheme (for testing purposes)
   !!
   !! This method allows tests to override the scheme configuration
   !! to test different schemes programmatically.
   !!
   !! @param[inout] this The Process{{ config.class_name }}Interface instance
   !! @param[in] scheme_name The scheme name to set
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
   !! @param[in] gas_scheme Optional: if true, set gas_scheme; if false, set aero_scheme
   subroutine set_{{ config.name }}_scheme(this, scheme_name, gas_scheme)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      character(len=*), intent(in) :: scheme_name
      logical, intent(in), optional :: gas_scheme

      logical :: is_gas

      ! Default to setting the single scheme for backward compatibility
      is_gas = .true.
      if (present(gas_scheme)) is_gas = gas_scheme

      if (is_gas) then
         this%process_config%{{ config.name }}_config%gas_scheme = trim(scheme_name)
      else
         this%process_config%{{ config.name }}_config%aero_scheme = trim(scheme_name)
      end if
{% else %}
   subroutine set_{{ config.name }}_scheme(this, scheme_name)
      class(Process{{ config.class_name }}Interface), intent(inout) :: this
      character(len=*), intent(in) :: scheme_name

      this%process_config%{{ config.name }}_config%scheme = trim(scheme_name)
{% endif %}

   end subroutine set_{{ config.name }}_scheme

   !> Get the current active scheme
   !!
   !! This method allows retrieval of the current scheme for testing
   !! and verification purposes.
   !!
   !! @param[in] this The Process{{ config.class_name }}Interface instance
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
   !! @param[in] gas_scheme Optional: if true, get gas_scheme; if false, get aero_scheme
   !! @returns The current scheme name
   function get_{{ config.name }}_scheme(this, gas_scheme) result(scheme_name)
      class(Process{{ config.class_name }}Interface), intent(in) :: this
      logical, intent(in), optional :: gas_scheme
      character(len=64) :: scheme_name

      logical :: is_gas

      ! Default to getting the gas scheme for backward compatibility
      is_gas = .true.
      if (present(gas_scheme)) is_gas = gas_scheme

      if (is_gas) then
         scheme_name = trim(this%process_config%{{ config.name }}_config%gas_scheme)
      else
         scheme_name = trim(this%process_config%{{ config.name }}_config%aero_scheme)
      end if
{% else %}
   !! @returns The current scheme name
   function get_{{ config.name }}_scheme(this) result(scheme_name)
      class(Process{{ config.class_name }}Interface), intent(in) :: this
      character(len=64) :: scheme_name

      scheme_name = trim(this%process_config%{{ config.name }}_config%scheme)
{% endif %}

   end function get_{{ config.name }}_scheme

