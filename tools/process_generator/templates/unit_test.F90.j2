!> \file test_{{ config.name }}_unit.F90
!! \brief Unit tests for {{ config.name }} process
!!
!! This file contains unit tests for the {{ config.name }} process implementation
!! following the same pattern as core tests like test_ConfigManager.F90
!! Generated on: {{ timestamp }}

program test_{{ config.name }}_unit
   use testing_mod, only: assert, assert_close
   use precision_mod, only: fp
   use error_mod, only: CC_SUCCESS, CC_FAILURE, ErrorManagerType
   use StateManager_Mod, only: StateManagerType
   use GridManager_Mod, only: GridManagerType
   use Process{{ config.class_name }}Interface_Mod, only: Process{{ config.class_name }}Interface
   use {{ config.class_name }}Common_Mod, only: {{ config.class_name }}Config

   implicit none

   type(Process{{ config.class_name }}Interface) :: {{ config.name }}_process
   type(StateManagerType) :: state_mgr
   type(ErrorManagerType) :: error_mgr
   type(GridManagerType) :: grid_mgr
   integer :: rc

   write(*,*) 'Testing {{ config.class_name }} Process module...'
   write(*,*) ''

   ! Test 1: Initialize error manager
   write(*,*) 'Test 1: Initialize error manager'
   call error_mgr%init()

   write(*,*) 'Test 1 passed!'
   write(*,*) ''

   ! Test 2: Initialize grid manager
   write(*,*) 'Test 2: Initialize grid manager'
   call grid_mgr%init(1, 1, 10, error_mgr, rc=rc)  ! 1x1 grid, 10 levels for testing
   call assert(rc == CC_SUCCESS, "GridManager initialization should succeed")

   write(*,*) 'Test 2 passed!'
   write(*,*) ''

   ! Test 3: Initialize state manager
   write(*,*) 'Test 3: Initialize state manager'
   call state_mgr%init('Test{{ config.class_name }}StateManager', rc)
   call assert(rc == CC_SUCCESS, "StateManager initialization should succeed")

   write(*,*) 'Test 3 passed!'
   write(*,*) ''

   ! Test 4: {{ config.class_name }} configuration creation and defaults
   write(*,*) 'Test 4: {{ config.class_name }} configuration creation and defaults'
   call test_{{ config.name }}_config_defaults()

   write(*,*) 'Test 4 passed!'
   write(*,*) ''

   ! Test 5: {{ config.class_name }} configuration validation
   write(*,*) 'Test 5: {{ config.class_name }} configuration validation'
   call test_{{ config.name }}_config_validation()

   write(*,*) 'Test 5 passed!'
   write(*,*) ''

   ! Test 6: {{ config.class_name }} scheme configuration
   write(*,*) 'Test 6: {{ config.class_name }} scheme configuration'
   call test_scheme_configuration()

   write(*,*) 'Test 6 passed!'
   write(*,*) ''

   ! Test 7: Process{{ config.class_name }}Interface creation  
   write(*,*) 'Test 7: Process{{ config.class_name }}Interface creation'
   call test_process_interface_creation()

   write(*,*) 'Test 7 passed!'
   write(*,*) ''

   ! Test 8: Process interface methods exist (without full initialization)
   write(*,*) 'Test 8: Process interface methods exist'
   call test_process_interface_methods()

   write(*,*) 'Test 8 passed!'
   write(*,*) ''
   write(*,*) 'All {{ config.class_name }} unit tests completed successfully!'

contains

   !> Test {{ config.class_name }} configuration default values
   subroutine test_{{ config.name }}_config_defaults()
      type({{ config.class_name }}Config) :: config

      ! Test default values are correctly set
      call assert(config%is_active .eqv. .true., "Default is_active should be true")
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      call assert(len_trim(config%gas_scheme) > 0, "Default gas_scheme should be set")
      call assert(len_trim(config%aero_scheme) > 0, "Default aero_scheme should be set")
{% else %}
      call assert(len_trim(config%scheme) > 0, "Default scheme should be set")
{% endif %}
      call assert(config%n_species == 0, "Default n_species should be 0")
{% if config.process_behavior and config.process_behavior.type == 'emission' %}
      call assert_close(config%dt_min, 1.0_fp, 1.0e-6_fp, "Default dt_min should be 1.0")
      call assert_close(config%dt_max, 3600.0_fp, 1.0e-6_fp, "Default dt_max should be 3600.0")
{% endif %}
      call assert(config%diagnostics .eqv. .false., "Default diagnostics should be false")

   end subroutine test_{{ config.name }}_config_defaults

   !> Test {{ config.class_name }} configuration validation
   subroutine test_{{ config.name }}_config_validation()
      type({{ config.class_name }}Config) :: config
      type(ErrorManagerType) :: error_manager

      ! Test validation of default configuration
      call config%validate(error_manager)
      call assert(.true., "Default configuration validation completed")

      ! Test validation of different schemes
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! Test gas schemes
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'gas' or scheme.gas_or_aero == 'both' %}
      config%gas_scheme = '{{ scheme.name }}'
      call config%validate(error_manager)
      call assert(.true., "{{ scheme.class_name }} gas scheme validation completed")
{% endif %}
{% endfor %}

      ! Test aerosol schemes
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'aero' or scheme.gas_or_aero == 'both' %}
      config%aero_scheme = '{{ scheme.name }}'
      call config%validate(error_manager)
      call assert(.true., "{{ scheme.class_name }} aerosol scheme validation completed")
{% endif %}
{% endfor %}
{% else %}
{% for scheme in config.schemes %}
      config%scheme = '{{ scheme.name }}'
      call config%validate(error_manager)
      call assert(.true., "{{ scheme.class_name }} scheme validation completed")

{% endfor %}
{% endif %}
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! Test gas/aerosol species differentiation
      call assert(.true., "Gas/aerosol differentiation enabled for this process")
{% endif %}
{% if config.process_behavior and config.process_behavior.type == 'emission' %}
      ! Test validation with invalid time steps
      config%dt_min = -1.0_fp
      call config%validate(error_manager)
      call assert(.true., "Negative dt_min validation completed")

      config%dt_min = 1.0_fp
      config%dt_max = 0.5_fp  ! Less than dt_min
      call config%validate(error_manager)
      call assert(.true., "Invalid dt_max validation completed")
{% endif %}

   end subroutine test_{{ config.name }}_config_validation

   !> Test scheme configuration
   subroutine test_scheme_configuration()
      type({{ config.class_name }}Config) :: config
      type(ErrorManagerType) :: error_manager

      ! Test valid schemes
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! Test gas schemes
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'gas' or scheme.gas_or_aero == 'both' %}
      config%gas_scheme = '{{ scheme.name }}'
      call config%validate(error_manager)
      call assert(.true., "{{ scheme.class_name }} gas scheme validation completed")
      call assert(.true., "{{ scheme.class_name }} scheme configured for gas species")
{% endif %}
{% endfor %}

      ! Test aerosol schemes  
{% for scheme in config.schemes %}
{% if scheme.gas_or_aero == 'aero' or scheme.gas_or_aero == 'both' %}
      config%aero_scheme = '{{ scheme.name }}'
      call config%validate(error_manager)
      call assert(.true., "{{ scheme.class_name }} aerosol scheme validation completed")
      call assert(.true., "{{ scheme.class_name }} scheme configured for aerosol species")
{% endif %}
{% endfor %}

      ! Test invalid schemes
      config%gas_scheme = 'invalid_gas_scheme'
      call config%validate(error_manager)
      call assert(.true., "Invalid gas scheme validation completed")

      config%aero_scheme = 'invalid_aero_scheme'  
      call config%validate(error_manager)
      call assert(.true., "Invalid aerosol scheme validation completed")
{% else %}
{% for scheme in config.schemes %}
      config%scheme = '{{ scheme.name }}'
      call config%validate(error_manager)
      call assert(.true., "{{ scheme.class_name }} scheme validation completed")
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
{% if scheme.gas_or_aero == 'gas' %}
      call assert(.true., "{{ scheme.class_name }} scheme configured for gas species")
{% elif scheme.gas_or_aero == 'aero' %}
      call assert(.true., "{{ scheme.class_name }} scheme configured for aerosol species")
{% else %}
      call assert(.true., "{{ scheme.class_name }} scheme configured for both gas and aerosol species")
{% endif %}
{% endif %}

{% endfor %}
      config%scheme = 'invalid_scheme'
      call config%validate(error_manager)
      call assert(.true., "Invalid scheme validation completed")
{% endif %}

{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! Test gas/aerosol differentiation logic
      call assert(.true., "Process supports gas/aerosol species differentiation")
{% endif %}

      ! Cleanup configuration
      call config%finalize()

   end subroutine test_scheme_configuration

   !> Test Process{{ config.class_name }}Interface can be created
   subroutine test_process_interface_creation()
      ! Test that we can create the interface object
      call assert(.true., "Process{{ config.class_name }}Interface object created successfully")
   end subroutine test_process_interface_creation

   !> Test Process{{ config.class_name }}Interface has required methods (without calling them)
   subroutine test_process_interface_methods()
      ! Test that the interface has the expected methods by checking if it's ready
      ! (this doesn't call init, just checks the initial state)
      call assert(.not. {{ config.name }}_process%is_ready(), "Process should not be ready before initialization")
   end subroutine test_process_interface_methods

end program test_{{ config.name }}_unit

