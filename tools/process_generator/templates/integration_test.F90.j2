!> \file test_{{ config.name }}_integration.F90
!! \brief Comprehensive integration tests for {{ config.name }} process using CATChemCore
!!
!! This file contains comprehensive integration tests for the {{ config.name }} process implementation
!! using the centralized CATChemCore framework. Tests complete workflow: core initialization,
!! configuration loading, process registration, and all scheme validation.
!! Generated on: {{ timestamp }}

program test_{{ config.name }}_integration
   use precision_mod, only: fp
   use iso_fortran_env, only: output_unit, error_unit
   use error_mod, only: CC_SUCCESS, CC_FAILURE, ErrorManagerType, ERROR_UNSUPPORTED_OPERATION
   use CATChemCore_Mod, only: CATChemCoreType, CATChemBuilderType
   use StateManager_Mod, only: StateManagerType
   use ProcessManager_Mod, only: ProcessManagerType
   use GridManager_Mod, only: GridManagerType
   use DiagnosticManager_Mod, only: DiagnosticManagerType
   use MetState_Mod, only: MetStateType
   use ChemState_Mod, only: ChemStateType
   use ConfigManager_Mod, only: ConfigManagerType
   use Process{{ config.class_name }}Interface_Mod, only: Process{{ config.class_name }}Interface
   use {{ config.class_name }}ProcessCreator_Mod, only: register_{{ config.name }}_process
   use {{ config.class_name }}Common_Mod, only: {{ config.class_name }}ProcessConfig
   use DiagnosticInterface_Mod, only: DiagnosticRegistryType, DiagnosticFieldType, &
                                      DIAG_REAL_SCALAR, DIAG_REAL_1D, DIAG_REAL_2D, DIAG_REAL_3D, &
                                      DIAG_INTEGER_SCALAR, DIAG_INTEGER_1D, DIAG_INTEGER_2D, DIAG_INTEGER_3D

   implicit none

   ! Core framework
   type(CATChemCoreType) :: core
   type(CATChemBuilderType) :: builder
   type(ProcessManagerType), pointer :: process_mgr_ptr

   ! Configuration file path
   character(len=*), parameter :: config_file = './CATChem_new_config.yml'

   ! Test parameters for realistic {{ config.process_type }} scenario
   integer, parameter :: n_columns = 10    ! Grid columns
   integer, parameter :: n_levels = 20     ! Vertical levels (surface to ~20 km)
   integer, parameter :: n_time_steps = 5  ! Multiple timesteps for integration testing
   real(fp), parameter :: dt = 3600.0_fp   ! 1 hour timestep

{% if config.schemes %}
   ! Test schemes
   character(len=20) :: schemes({{ config.schemes|length }})
{% endif %}

   integer :: rc, i_scheme, i_time
   logical :: all_tests_passed = .true.

{% if config.schemes %}
   ! Initialize scheme array
   schemes = [ &
{% for scheme in config.schemes %}
      '{{ scheme.name.ljust(20) }}'{% if not loop.last %}, &
{% else %}]
{% endif %}
{% endfor %}
{% endif %}

   write(output_unit,'(A)') '=================================='
   write(output_unit,'(A)') '=== {{ config.name|upper }} INTEGRATION TESTS ==='
   write(output_unit,'(A)') '=================================='
   write(output_unit,'(A)') 'Using CATChemCore for comprehensive testing with'
   write(output_unit,'(A)') 'configuration, meteorological data, and all scheme validation'
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
   write(output_unit,'(A)') 'Process supports gas/aerosol species differentiation'
{% endif %}
   write(output_unit,'(A)') ''

   ! Step 1: Initialize CATChem Core with proper grid dimensions
   write(output_unit,'(A)') 'Step 1: Initializing CATChem Core...'
   
   call builder%init()
   builder = builder%with_name('{{ config.class_name }}IntegrationTest')
   builder = builder%with_config(config_file)
   builder = builder%with_grid(n_columns, 1, n_levels)
   builder = builder%with_verbose()
   call builder%build(core, rc)
   
   if (rc /= CC_SUCCESS) then
      write(error_unit,'(A)') 'ERROR: CATChemCore initialization/configuration failed'
      all_tests_passed = .false.
      goto 999
   end if
   write(output_unit,'(A,I0,A,I0,A)') '  ✓ CATChemCore initialized: ', n_columns, ' columns, ', n_levels, ' levels'
   write(output_unit,'(A)') '  ✓ Configuration loaded and all managers set up'

   ! Register {{ config.name }} processes with ProcessFactory
   process_mgr_ptr => core%get_process_manager()
   call register_{{ config.name }}_process(process_mgr_ptr, rc)
   if (rc /= CC_SUCCESS) then
      write(error_unit,'(A)') 'ERROR: Failed to register {{ config.name }} processes with ProcessFactory'
      all_tests_passed = .false.
      goto 999
   end if
   write(output_unit,'(A)') '  ✓ {{ config.class_name }} processes registered with ProcessFactory'

   ! Step 2: Set up realistic meteorological conditions  
   write(output_unit,'(A)') ''
   write(output_unit,'(A)') 'Step 2: Setting up realistic meteorological conditions...'
   call setup_met(core, rc)
   if (rc /= CC_SUCCESS) then
      write(error_unit,'(A)') 'ERROR: Failed to set up meteorological conditions'
      all_tests_passed = .false.
      goto 999
   end if
   write(output_unit,'(A)') '  ✓ Meteorological conditions configured'

{% if config.schemes %}
   ! Step 3: Testing {{ config.name }} process with all schemes
   write(output_unit,'(A)') ''
   write(output_unit,'(A)') 'Step 3: Testing {{ config.name }} process with all schemes...'
   
   ! Add {{ config.name }} process for scheme testing
   call core%add_process('{{ config.name }}', rc)
   if (rc /= CC_SUCCESS) then
      write(error_unit,'(A)') 'ERROR: Failed to add {{ config.name }} process for scheme testing'
      all_tests_passed = .false.
      goto 999
   end if
   write(output_unit,'(A)') '  ✓ {{ config.class_name }} process added successfully'

   write(output_unit,'(A)') ''
   write(output_unit,'(A)') '  Testing multiple {{ config.name }} schemes...'
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
   write(output_unit,'(A)') '  Process supports gas/aerosol species differentiation'
{% endif %}
   do i_scheme = 1, size(schemes)
      write(output_unit,'(A,A,A)') '    Testing ', trim(schemes(i_scheme)), ' scheme...'
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
{% for scheme in config.schemes %}
      if (trim(schemes(i_scheme)) == '{{ scheme.name }}') then
{% if scheme.gas_or_aero == 'gas' %}
         write(output_unit,'(A)') '      Scheme handles gas species'
{% elif scheme.gas_or_aero == 'aero' %}
         write(output_unit,'(A)') '      Scheme handles aerosol species'
{% else %}
         write(output_unit,'(A)') '      Scheme handles both gas and aerosol species'
{% endif %}
      end if
{% endfor %}
{% endif %}
      
      call test_scheme(core, schemes(i_scheme), rc)
      if (rc /= CC_SUCCESS) then
         write(output_unit,'(A,A)') '    ✗ ', trim(schemes(i_scheme)), ' scheme test failed'
         write(error_unit,'(A,A)') 'ERROR: Scheme test failed for ', trim(schemes(i_scheme))
         all_tests_passed = .false.
      else
         write(output_unit,'(A,A)') '    ✓ ', trim(schemes(i_scheme)), ' scheme test passed'
      end if
   end do
   write(output_unit,'(A)') '  ✓ All scheme tests completed'
{% endif %}

   ! Step {{ '4' if config.schemes else '3' }}: Test multi-timestep stability
   write(output_unit,'(A)') ''
   write(output_unit,'(A)') 'Step {{ '4' if config.schemes else '3' }}: Testing multi-timestep stability...'
   write(output_unit,'(A,I0,A)') '  Running ', n_time_steps, ' timestep integration test...'

{% if not config.schemes %}
   ! Add {{ config.name }} process for timestep testing (only if not already added in scheme testing)
   call core%add_process('{{ config.name }}', rc)
   if (rc /= CC_SUCCESS) then
      write(error_unit,'(A)') 'ERROR: Failed to add {{ config.name }} process for timestep testing'
      all_tests_passed = .false.
      goto 999
   end if
{% endif %}

   do i_time = 1, n_time_steps
      call core%run_timestep(i_time, dt, rc)
      if (rc /= CC_SUCCESS) then
         write(error_unit,'(A,I0)') 'ERROR: Timestep ', i_time, ' failed'
         all_tests_passed = .false.
         exit
      end if
   end do
   
   if (all_tests_passed) then
      write(output_unit,'(A,I0,A)') '  ✓ All ', n_time_steps, ' timesteps completed successfully'
      write(output_unit,'(A)') '    - {{ config.class_name }} process stability verified'
      write(output_unit,'(A)') '    - Multi-timestep conservation maintained'
   end if

   ! Final validation and cleanup
   write(output_unit,'(A)') ''
   write(output_unit,'(A)') 'Final validation and cleanup...'
   call core%finalize(rc)
   if (rc /= CC_SUCCESS) then
      write(error_unit,'(A)') 'WARNING: Core finalization had issues'
   end if

999 continue

   ! Print final results
   write(output_unit,'(A)') ''
   write(output_unit,'(A)') '=================================='
   if (all_tests_passed) then
      write(output_unit,'(A)') '=== ALL {{ config.name|upper }} TESTS PASSED! ==='
      write(output_unit,'(A)') '=== Integration test successful ==='
   else
      write(output_unit,'(A)') '=== SOME {{ config.name|upper }} TESTS FAILED ==='
      write(output_unit,'(A)') '=== Check error messages above ==='
   end if
   write(output_unit,'(A)') '=================================='

   if (.not. all_tests_passed) stop 1

contains

   !> Set up realistic meteorological conditions for {{ config.name }} testing
   subroutine setup_met(core_arg, rc_arg)
      type(CATChemCoreType), intent(inout) :: core_arg
      integer, intent(out) :: rc_arg
      
      type(StateManagerType), pointer :: state_mgr
      type(MetStateType), pointer :: met_state
      type(GridManagerType), pointer :: grid_mgr
      integer :: nx, ny, nz, i, j, k
      real(fp) :: lat, wind_speed, altitude_km, edge_altitude_km
      
      rc_arg = CC_SUCCESS
      
      ! Get managers and state pointers
      state_mgr => core_arg%get_state_manager()
      met_state => state_mgr%get_met_state_ptr()
      grid_mgr => core_arg%get_grid_manager()
      
      ! Get grid dimensions
      call grid_mgr%get_shape(nx, ny, nz)
      
      ! Allocate categorical arrays with standard dimensions
{% if required_met_fields and ('SOILM' in required_met_fields or 'FRLANDUSE' in required_met_fields or 'FRSOIL' in required_met_fields or 'FRLAI' in required_met_fields or 'ILAND' in required_met_fields) %}
{% if required_met_fields and 'SOILM' in required_met_fields %}
      if (.not. allocated(met_state%SOILM)) then
         allocate(met_state%SOILM(nx, ny, 4))  ! nsoil=4 soil layers
      end if
{% endif %}
{% if required_met_fields and 'FRLANDUSE' in required_met_fields %}
      if (.not. allocated(met_state%FRLANDUSE)) then
         allocate(met_state%FRLANDUSE(nx, ny, 20))  ! nSURFTYPE=20 land use types
      end if
{% endif %}
{% if required_met_fields and 'FRSOIL' in required_met_fields %}
      if (.not. allocated(met_state%FRSOIL)) then
         allocate(met_state%FRSOIL(nx, ny, 19))  ! nsoiltype=19 soil types
      end if
{% endif %}
{% if required_met_fields and 'FRLAI' in required_met_fields %}
      if (.not. allocated(met_state%FRLAI)) then
         allocate(met_state%FRLAI(nx, ny, 20))  ! nSURFTYPE=20 (LAI per land use type)
      end if
{% endif %}
{% if required_met_fields and 'ILAND' in required_met_fields %}
      if (.not. allocated(met_state%ILAND)) then
         allocate(met_state%ILAND(nx, ny, 20))  ! nSURFTYPE=20 land use types (integer IDs)
      end if
{% endif %}
{% endif %}
      
      ! Set realistic conditions for {{ config.name }} processes
      do j = 1, ny
         ! Calculate latitude for realistic gradients
         lat = -30.0_fp + (j-1) * 60.0_fp / max(1, ny-1)  ! -30°S to 30°N
         do i = 1, nx
         {%- set sep = namespace(value='            ') %}

{% if required_met_fields and 'AREA_M2' in required_met_fields %}
{{- sep.value -}} met_state%AREA_M2(i,j) = 1.0e8_fp                  ! Grid box area [m2]
{%- set sep.value = '\n            ' %}
{%- endif %}

{%- if required_met_fields and 'LAT' in required_met_fields %}
{{- sep.value -}} met_state%LAT(i,j) = lat                           ! Latitude [degrees]
{%- set sep.value = '\n            ' %}
{%- endif %}

{%- if required_met_fields and 'LON' in required_met_fields %}
{{- sep.value -}} met_state%LON(i,j) = -120.0_fp + (i-1) * 240.0_fp / max(1, nx-1)  ! Longitude [degrees]
{%- set sep.value = '\n            '%}
{%- endif %}

{%- if required_met_fields and 'FROCEAN' in required_met_fields %}
{{- sep.value -}} met_state%FROCEAN(i,j) = 1.0_fp                    ! Pure ocean everywhere
{%- set sep.value = '\n            ' %}
{%- endif %}

{%- if required_met_fields and 'FRSEAICE' in required_met_fields %}
{{- sep.value -}} met_state%FRSEAICE(i,j) = 0.0_fp                   ! No sea ice
{%- set sep.value = '\n            ' %}
{%- endif %}

{%- if required_met_fields and 'FRLAND' in required_met_fields %}
{{- sep.value -}} met_state%FRLAND(i,j) = 0.0_fp                     ! No land (pure ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}

{%- if required_met_fields and 'FRLANDIC' in required_met_fields %}
{{- sep.value -}} met_state%FRLANDIC(i,j) = 0.0_fp                   ! No land ice
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'FRLAKE' in required_met_fields %}
{{- sep.value -}} met_state%FRLAKE(i,j) = 0.0_fp                     ! No lakes
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'FRSNO' in required_met_fields %}
{{- sep.value -}} met_state%FRSNO(i,j) = 0.0_fp                      ! No snow
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SST' in required_met_fields %}
{{- sep.value -}} met_state%SST(i,j) = 298.0_fp + 5.0_fp * cos(lat * 3.14159_fp / 180.0_fp)  ! 293-303K SST
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'TS' in required_met_fields %}
{{- sep.value -}} met_state%TS(i,j) = 298.0_fp + 5.0_fp * cos(lat * 3.14159_fp / 180.0_fp)   ! Surface temperature [K]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'TSKIN' in required_met_fields %}
{{- sep.value -}} met_state%TSKIN(i,j) = 298.0_fp + 5.0_fp * cos(lat * 3.14159_fp / 180.0_fp) ! Skin temperature [K]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'T2M' in required_met_fields %}
{{- sep.value -}} met_state%T2M(i,j) = 298.0_fp + 5.0_fp * cos(lat * 3.14159_fp / 180.0_fp)  ! 2m temperature [K]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PS' in required_met_fields %}
{{- sep.value -}} met_state%PS(i,j) = 101300.25_fp                     ! Surface pressure [Pa]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SLP' in required_met_fields %}
{{- sep.value -}} met_state%SLP(i,j) = 101300.25_fp                    ! Sea level pressure [Pa]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PS_WET' in required_met_fields %}
{{- sep.value -}} met_state%PS_WET(i,j) = 101300.25_fp                 ! Wet surface pressure [Pa]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PS_DRY' in required_met_fields %}
{{- sep.value -}} met_state%PS_DRY(i,j) = 101000.0_fp                  ! Dry surface pressure [Pa]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'QV2M' in required_met_fields %}
{{- sep.value -}} met_state%QV2M(i,j) = 0.012_fp                     ! 2m specific humidity [kg/kg]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and ('U10M' in required_met_fields or 'V10M' in required_met_fields or 'USTAR' in required_met_fields) %}
{{- sep.value }}wind_speed = 8.0_fp + 2.0_fp * cos(lat * 3.14159_fp / 180.0_fp)  ! 6-10 m/s
{%- set sep.value = '\n            ' %}
{%- if required_met_fields and 'U10M' in required_met_fields %}
{{- sep.value -}} met_state%U10M(i,j) = -wind_speed * 0.8_fp         ! Easterly trade winds
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'V10M' in required_met_fields %}
{{- sep.value -}} met_state%V10M(i,j) = wind_speed * 0.3_fp          ! Slight northerly component
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'USTAR' in required_met_fields %}
{{- sep.value -}} met_state%USTAR(i,j) = 0.03_fp * sqrt(met_state%U10M(i,j)**2 + met_state%V10M(i,j)**2)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- endif %}           
{%- if required_met_fields and 'Z0' in required_met_fields %}
{{- sep.value -}} met_state%Z0(i,j) = 0.0002_fp                      ! Ocean surface roughness [m]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'Z0H' in required_met_fields %}
{{- sep.value -}} met_state%Z0H(i,j) = 0.0001_fp                     ! Thermal roughness [m]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PBLH' in required_met_fields %}
{{- sep.value -}} met_state%PBLH(i,j) = 800.0_fp                     ! PBL height [m]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'OBK' in required_met_fields %}
{{- sep.value -}} met_state%OBK(i,j) = -50.0_fp                      ! Monin-Obukhov length [m]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'HFLUX' in required_met_fields %}
{{- sep.value -}} met_state%HFLUX(i,j) = 15.0_fp                     ! Sensible heat flux [W/m2]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'EFLUX' in required_met_fields %}
{{- sep.value -}} met_state%EFLUX(i,j) = 120.0_fp                    ! Latent heat flux [W/m2]
{%- set sep.value = '\n            ' %}
{%- endif %}           
{%- if required_met_fields and 'SWGDN' in required_met_fields %}
{{- sep.value -}} met_state%SWGDN(i,j) = 800.0_fp * max(0.0_fp, cos(lat * 3.14159_fp / 180.0_fp)) ! Solar radiation [W/m2]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SUNCOS' in required_met_fields %}
{{- sep.value -}} met_state%SUNCOS(i,j) = max(0.1_fp, cos(lat * 3.14159_fp / 180.0_fp)) ! Solar zenith angle cosine
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SUNCOSmid' in required_met_fields %}
{{- sep.value -}} met_state%SUNCOSmid(i,j) = max(0.1_fp, cos(lat * 3.14159_fp / 180.0_fp)) ! Mid-timestep solar zenith
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'ALBD_VIS' in required_met_fields %}
{{- sep.value -}} met_state%ALBD_VIS(i,j) = 0.06_fp                  ! Ocean visible albedo
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'ALBD_NIR' in required_met_fields %}
{{- sep.value -}} met_state%ALBD_NIR(i,j) = 0.06_fp                  ! Ocean near-IR albedo
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'ALBD_UV' in required_met_fields %}
{{- sep.value -}} met_state%ALBD_UV(i,j) = 0.06_fp                   ! Ocean UV albedo
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PARDR' in required_met_fields %}
{{- sep.value -}} met_state%PARDR(i,j) = 300.0_fp * max(0.0_fp, cos(lat * 3.14159_fp / 180.0_fp)) ! Direct PAR [W/m2]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PARDF' in required_met_fields %}
{{- sep.value -}} met_state%PARDF(i,j) = 200.0_fp * max(0.0_fp, cos(lat * 3.14159_fp / 180.0_fp)) ! Diffuse PAR [W/m2]
{%- set sep.value = '\n            ' %}
{%- endif %}            
{%- if required_met_fields and 'CLDFRC' in required_met_fields %}
{{- sep.value -}} met_state%CLDFRC(i,j) = 0.3_fp                     ! Column cloud fraction
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'CNV_FRC' in required_met_fields %}
{{- sep.value -}} met_state%CNV_FRC(i,j) = 0.1_fp                    ! Convective fraction
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'CONV_DEPTH' in required_met_fields %}
{{- sep.value -}} met_state%CONV_DEPTH(i,j) = 2000.0_fp              ! Convective depth [m]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PRECCON' in required_met_fields %}
{{- sep.value -}} met_state%PRECCON(i,j) = 0.0_fp                    ! Convective precipitation [kg/m2/s]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PRECLSC' in required_met_fields %}
{{- sep.value -}} met_state%PRECLSC(i,j) = 0.0_fp                    ! Large-scale precipitation [kg/m2/s]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PRECANV' in required_met_fields %}
{{- sep.value -}} met_state%PRECANV(i,j) = 0.0_fp                    ! Anvil precipitation [kg/m2/s]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'FLASH_DENS' in required_met_fields %}
{{- sep.value -}} met_state%FLASH_DENS(i,j) = 0.0_fp                 ! Lightning flash density [#/km2/s]
{%- set sep.value = '\n            ' %}
{%- endif %}           
{%- if required_met_fields and 'TO3' in required_met_fields %}
{{- sep.value -}} met_state%TO3(i,j) = 300.0_fp                      ! Total O3 column [DU]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'TROPP' in required_met_fields %}
{{- sep.value -}} met_state%TROPP(i,j) = 20000.0_fp                    ! Tropopause pressure [Pa]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'TropHt' in required_met_fields %}
{{- sep.value -}} met_state%TropHt(i,j) = 12.0_fp                    ! Tropopause height [km]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'PHIS' in required_met_fields %}
{{- sep.value -}} met_state%PHIS(i,j) = 0.0_fp                       ! Surface geopotential [m2/s2] (sea level)
{%- set sep.value = '\n            ' %}
{%- endif %}            
{%- if required_met_fields and 'LAI' in required_met_fields %}
{{- sep.value -}} met_state%LAI(i,j) = 0.0_fp                        ! Leaf area index (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'GVF' in required_met_fields %}
{{- sep.value -}} met_state%GVF(i,j) = 0.0_fp                        ! Green vegetation fraction (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'FRVEG' in required_met_fields %}
{{- sep.value -}} met_state%FRVEG(i,j) = 0.0_fp                      ! Vegetation fraction (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}            
{%- if required_met_fields and 'CLAYFRAC' in required_met_fields %}
{{- sep.value -}} met_state%CLAYFRAC(i,j) = 0.0_fp                   ! Clay fraction (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SANDFRAC' in required_met_fields %}
{{- sep.value -}} met_state%SANDFRAC(i,j) = 0.0_fp                   ! Sand fraction (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'GWETTOP' in required_met_fields %}
{{- sep.value -}} met_state%GWETTOP(i,j) = 0.0_fp                    ! Top soil moisture (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'GWETROOT' in required_met_fields %}
{{- sep.value -}} met_state%GWETROOT(i,j) = 0.0_fp                   ! Root zone soil moisture (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'WILT' in required_met_fields %}
{{- sep.value -}} met_state%WILT(i,j) = 0.0_fp                       ! Wilting point (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}           
{%- if required_met_fields and 'SNODP' in required_met_fields %}
{{- sep.value -}} met_state%SNODP(i,j) = 0.0_fp                      ! Snow depth [m]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SNOMAS' in required_met_fields %}
{{- sep.value -}} met_state%SNOMAS(i,j) = 0.0_fp                     ! Snow mass [kg/m2]
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'RDRAG' in required_met_fields %}
{{- sep.value -}} met_state%RDRAG(i,j) = 0.0_fp                      ! Drag partition (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'USTAR_THRESHOLD' in required_met_fields %}
{{- sep.value -}} met_state%USTAR_THRESHOLD(i,j) = 0.0_fp            ! Threshold friction velocity (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}
{%- if required_met_fields and 'SSM' in required_met_fields %}
{{- sep.value -}} met_state%SSM(i,j) = 0.0_fp                        ! Sediment supply map (ocean)
{%- set sep.value = '\n            ' %}
{%- endif %}

         end do
      end do      
{% set has_3d_fields = [] %}
{% for field in ['T', 'THETA', 'TV', 'U', 'V', 'OMEGA', 'QV', 'SPHU', 'RH', 'AVGW', 'PMID', 'PMID_DRY', 'DELP', 'DELP_DRY', 'AIRDEN', 'AIRNUMDEN', 'MAIRDEN', 'DAIRMASS', 'BXHEIGHT', 'AIRVOL', 'Z', 'ZMID', 'CLDF', 'QI', 'QL', 'TAUCLI', 'TAUCLW', 'CMFMC', 'DTRAIN', 'DQRCU', 'DQRLSAN', 'PFICU', 'PFILSAN', 'PFLCU', 'PFLLSAN', 'F_OF_PBL', 'F_UNDER_PBLTOP'] %}
  {% if required_met_fields and field in required_met_fields %}
    {% if has_3d_fields.append(field) %}{% endif %}
  {% endif %}
{% endfor %}

{% if has_3d_fields %}
      ! Set up 3D atmospheric fields (nx, ny, nz)
      do j = 1, ny
         do i = 1, nx
            do k = 1, nz
               ! Calculate height-dependent values
               ! Approximate altitude in km (assuming ~1 km per level near surface)
               altitude_km = real(k-1, fp) * 1.0_fp
               {%- set sep = namespace(value='               ') %}
               
{% if required_met_fields and 'T' in required_met_fields %}{{- sep.value -}}
               met_state%T(i,j,k) = 288.15_fp - 6.5_fp * altitude_km  ! Temperature lapse rate [K]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'THETA' in required_met_fields %}{{- sep.value -}}
               met_state%THETA(i,j,k) = met_state%T(i,j,k) * (1000.0_fp / (1013.25_fp - 50.0_fp * altitude_km))**(0.286_fp)  ! Potential temperature
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'TV' in required_met_fields %}{{- sep.value -}}
               met_state%TV(i,j,k) = met_state%T(i,j,k) * 1.01_fp     ! Virtual temperature [K]
{%- set sep.value = '\n               ' %}{%- endif %}              
{%- if required_met_fields and 'U' in required_met_fields %}{{- sep.value -}}
               met_state%U(i,j,k) = -10.0_fp * (1.0_fp + 0.1_fp * altitude_km)  ! Easterly winds increasing with height
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'V' in required_met_fields %}{{- sep.value -}}
               met_state%V(i,j,k) = 2.0_fp * (1.0_fp + 0.05_fp * altitude_km)   ! Slight northerly component
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'OMEGA' in required_met_fields %}{{- sep.value -}}
               met_state%OMEGA(i,j,k) = -0.01_fp * sin(3.14159_fp * altitude_km / 10.0_fp)  ! Weak vertical motion [Pa/s]
{%- set sep.value = '\n               ' %}{%- endif %}             
{%- if required_met_fields and 'QV' in required_met_fields %}{{- sep.value -}}
               met_state%QV(i,j,k) = 0.015_fp * exp(-altitude_km / 2.0_fp)      ! Specific humidity [kg/kg]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'SPHU' in required_met_fields %}{{- sep.value -}}
               met_state%SPHU(i,j,k) = met_state%QV(i,j,k) * 1000.0_fp          ! Specific humidity [g/kg]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'RH' in required_met_fields %}{{- sep.value -}}
               met_state%RH(i,j,k) = 0.90_fp * exp(-altitude_km / 5.0_fp)       ! Relative humidity [fraction]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'AVGW' in required_met_fields %}{{- sep.value -}}
               met_state%AVGW(i,j,k) = met_state%QV(i,j,k) / (1.0_fp - met_state%QV(i,j,k))  ! Water vapor mixing ratio
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'PMID' in required_met_fields %}{{- sep.value -}}
               met_state%PMID(i,j,k) = 101300.25_fp * exp(-altitude_km / 8.0_fp)  ! Mid-level pressure [Pa]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'PMID_DRY' in required_met_fields %}{{- sep.value -}}
               met_state%PMID_DRY(i,j,k) = met_state%PMID(i,j,k) * 0.99_fp      ! Dry air pressure [Pa]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'DELP' in required_met_fields %}{{- sep.value -}}
               met_state%DELP(i,j,k) = 5000.0_fp                                  ! Pressure thickness [Pa]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'DELP_DRY' in required_met_fields %}{{- sep.value -}}
               met_state%DELP_DRY(i,j,k) = 4950.0_fp                              ! Dry pressure thickness [Pa]
{%- set sep.value = '\n               ' %}{%- endif %}              
{%- if required_met_fields and 'AIRDEN' in required_met_fields %}{{- sep.value -}}
               met_state%AIRDEN(i,j,k) = 1.2_fp * exp(-altitude_km / 8.0_fp)    ! Air density [kg/m3]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'AIRNUMDEN' in required_met_fields %}{{- sep.value -}}
               met_state%AIRNUMDEN(i,j,k) = 2.5e19_fp * exp(-altitude_km / 8.0_fp)  ! Air number density [molec/cm3]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'MAIRDEN' in required_met_fields %}{{- sep.value -}}
               met_state%MAIRDEN(i,j,k) = met_state%AIRDEN(i,j,k) * 1.01_fp     ! Moist air density [kg/m3]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'DAIRMASS' in required_met_fields %}{{- sep.value -}}
               met_state%DAIRMASS(i,j,k) = 1.2e8_fp * exp(-altitude_km / 8.0_fp) ! Dry air mass [kg]
{%- set sep.value = '\n               ' %}{%- endif %}               
{%- if required_met_fields and 'BXHEIGHT' in required_met_fields %}{{- sep.value -}}
               met_state%BXHEIGHT(i,j,k) = 1000.0_fp                            ! Grid box height [m]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'AIRVOL' in required_met_fields %}{{- sep.value -}}
               met_state%AIRVOL(i,j,k) = 1.0e11_fp                              ! Grid box volume [m3]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'Z' in required_met_fields %}{{- sep.value -}}
               met_state%Z(i,j,k) = altitude_km * 1000.0_fp * 9.81_fp           ! Geopotential height [m2/s2]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'ZMID' in required_met_fields %}{{- sep.value -}}
               met_state%ZMID(i,j,k) = altitude_km * 1000.0_fp * 9.81_fp        ! Mid-level geopotential [m2/s2]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'CLDF' in required_met_fields %}{{- sep.value -}}
               met_state%CLDF(i,j,k) = max(0.0_fp, 0.4_fp - altitude_km * 0.05_fp)  ! 3D cloud fraction
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'QI' in required_met_fields %}{{- sep.value -}}
               met_state%QI(i,j,k) = max(0.0_fp, 0.0001_fp * exp(-altitude_km / 3.0_fp))  ! Ice water content [kg/kg]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'QL' in required_met_fields %}{{- sep.value -}}
               met_state%QL(i,j,k) = max(0.0_fp, 0.0005_fp * exp(-altitude_km / 2.0_fp))  ! Liquid water content [kg/kg]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'TAUCLI' in required_met_fields %}{{- sep.value -}}
               met_state%TAUCLI(i,j,k) = max(0.0_fp, 0.1_fp * exp(-altitude_km / 4.0_fp))  ! Ice cloud optical depth
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'TAUCLW' in required_met_fields %}{{- sep.value -}}
               met_state%TAUCLW(i,j,k) = max(0.0_fp, 0.2_fp * exp(-altitude_km / 3.0_fp))  ! Water cloud optical depth
{%- set sep.value = '\n               ' %}{%- endif %}            
{%- if required_met_fields and 'CMFMC' in required_met_fields %}{{- sep.value -}}
               met_state%CMFMC(i,j,k) = max(0.0_fp, 0.001_fp * exp(-altitude_km / 5.0_fp))  ! Cloud mass flux [kg/m2/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'DTRAIN' in required_met_fields %}{{- sep.value -}}
               met_state%DTRAIN(i,j,k) = max(0.0_fp, 0.0001_fp * exp(-altitude_km / 6.0_fp))  ! Detrainment flux [kg/m2/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'DQRCU' in required_met_fields %}{{- sep.value -}}
               met_state%DQRCU(i,j,k) = 0.0_fp                                  ! Convective precip rate [kg/kg/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'DQRLSAN' in required_met_fields %}{{- sep.value -}}
               met_state%DQRLSAN(i,j,k) = 0.0_fp                                ! Large-scale precip rate [kg/kg/s]
{%- set sep.value = '\n               ' %}{%- endif %}         
{%- if required_met_fields and 'PFICU' in required_met_fields %}{{- sep.value -}}
               met_state%PFICU(i,j,k) = 0.0_fp                                  ! Ice precip flux: convective [kg/m2/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'PFILSAN' in required_met_fields %}{{- sep.value -}}
               met_state%PFILSAN(i,j,k) = 0.0_fp                                ! Ice precip flux: LS+anvil [kg/m2/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'PFLCU' in required_met_fields %}{{- sep.value -}}
               met_state%PFLCU(i,j,k) = 0.0_fp                                  ! Liquid precip flux: convective [kg/m2/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'PFLLSAN' in required_met_fields %}{{- sep.value -}}
               met_state%PFLLSAN(i,j,k) = 0.0_fp                                ! Liquid precip flux: LS+anvil [kg/m2/s]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'F_OF_PBL' in required_met_fields %}{{- sep.value -}}
               met_state%F_OF_PBL(i,j,k) = max(0.0_fp, 1.0_fp - altitude_km / 1.0_fp)  ! Fraction in PBL
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'F_UNDER_PBLTOP' in required_met_fields %}{{- sep.value -}}
               met_state%F_UNDER_PBLTOP(i,j,k) = max(0.0_fp, 1.0_fp - altitude_km / 1.2_fp)  ! Fraction under PBL top
{%- set sep.value = '\n               ' %}{%- endif %}

            end do
         end do
      end do
{% endif %}      
{% set has_edge_fields = [] %}
{% for field in ['PEDGE', 'PEDGE_DRY'] %}
  {% if required_met_fields and field in required_met_fields %}
    {% if has_edge_fields.append(field) %}{% endif %}
  {% endif %}
{% endfor %}
{% if has_edge_fields %}
      ! Set up pressure edge arrays (nx, ny, nz+1)
      do j = 1, ny
         do i = 1, nx
            do k = 1, nz+1
               edge_altitude_km = real(k-1, fp) * 1.0_fp - 0.5_fp
{%- if required_met_fields and 'PEDGE' in required_met_fields %}{{- sep.value -}}
               met_state%PEDGE(i,j,k) = 101300.25_fp * exp(-edge_altitude_km / 8.0_fp)  ! Pressure at edges [Pa]
{%- set sep.value = '\n               ' %}{%- endif %}
{%- if required_met_fields and 'PEDGE_DRY' in required_met_fields %}{{- sep.value -}}
               met_state%PEDGE_DRY(i,j,k) = met_state%PEDGE(i,j,k) * 0.99_fp    ! Dry pressure at edges [Pa]
{%- set sep.value = '\n               ' %}{%- endif %}

            end do
         end do
      end do
{% endif %}

{% set has_categorical_fields = [] %}
{% for field in ['SOILM', 'FRLANDUSE', 'FRSOIL', 'FRLAI', 'FRZ0'] %}
  {% if required_met_fields and field in required_met_fields %}
    {% if has_categorical_fields.append(field) %}{% endif %}
  {% endif %}
{% endfor %}
{% if has_categorical_fields %}
      ! Set up some arrays with special dimensions (nx, ny, ncat)
      do j = 1, ny
         do i = 1, nx
{%- if required_met_fields and 'SOILM' in required_met_fields %}{{- sep.value -}}
            ! Soil moisture in each layer - realistic profile
            do k = 1, size(met_state%SOILM, 3)  ! nsoil layers
               met_state%SOILM(i,j,k) = 0.35_fp - 0.06_fp * real(k-1, fp)  ! Decreasing with depth: 0.35, 0.29, 0.23...
            end do
{%- set sep.value = '\n            ' %}{%- endif %}
{%- if required_met_fields and 'FRLANDUSE' in required_met_fields %}{{- sep.value -}}
            ! Fractional land use types - realistic distribution
            do k = 1, size(met_state%FRLANDUSE, 3)  
               if (k == 1) then
                  met_state%FRLANDUSE(i,j,k) = 0.4_fp   ! Grassland/crop dominant
               else if (k == 2) then
                  met_state%FRLANDUSE(i,j,k) = 0.3_fp   ! Forest
               else if (k == 3) then
                  met_state%FRLANDUSE(i,j,k) = 0.2_fp   ! Urban/built
               else if (k <= 5) then
                  met_state%FRLANDUSE(i,j,k) = 0.05_fp  ! Wetland/water
               else
                  met_state%FRLANDUSE(i,j,k) = 0.0_fp   ! Other types
               end if
            end do
{%- set sep.value = '\n            ' %}{%- endif %}
{%- if required_met_fields and 'FRSOIL' in required_met_fields %}{{- sep.value -}}
            ! Fractional soil types - realistic distribution 
            do k = 1, size(met_state%FRSOIL, 3)  
               if (k == 1) then
                  met_state%FRSOIL(i,j,k) = 0.45_fp   ! Loam (most common)
               else if (k == 2) then
                  met_state%FRSOIL(i,j,k) = 0.25_fp   ! Clay loam
               else if (k == 3) then
                  met_state%FRSOIL(i,j,k) = 0.20_fp   ! Sandy loam
               else if (k <= 6) then
                  met_state%FRSOIL(i,j,k) = 0.025_fp  ! Other soil types
               else
                  met_state%FRSOIL(i,j,k) = 0.0_fp    ! Unused soil types
               end if
            end do
{%- set sep.value = '\n            ' %}{%- endif %}
{%- if required_met_fields and 'FRLAI' in required_met_fields %}{{- sep.value -}}
            ! LAI per land use type - realistic seasonal values
            do k = 1, size(met_state%FRLAI, 3)  
               if (k == 1) then
                  met_state%FRLAI(i,j,k) = 2.5_fp     ! Grassland/crop LAI
               else if (k == 2) then
                  met_state%FRLAI(i,j,k) = 4.2_fp     ! Forest LAI  
               else if (k == 3) then
                  met_state%FRLAI(i,j,k) = 0.5_fp     ! Urban vegetation
               else if (k <= 5) then
                  met_state%FRLAI(i,j,k) = 1.8_fp     ! Wetland vegetation
               else
                  met_state%FRLAI(i,j,k) = 0.1_fp     ! Sparse vegetation
               end if
            end do
{%- set sep.value = '\n            ' %}{%- endif %}
{%- if required_met_fields and 'ILAND' in required_met_fields %}{{- sep.value -}}
            ! Land use type indices - integer IDs for land use categories
            do k = 1, size(met_state%ILAND, 3)  
               if (k <= 20) then
                  met_state%ILAND(i,j,k) = k          ! Land use type ID (1-20)
               else
                  met_state%ILAND(i,j,k) = 1          ! Default to first type
               end if
            end do
{%- set sep.value = '\n            ' %}{%- endif %}
{%- if required_met_fields and 'FRZ0' in required_met_fields %}{{- sep.value -}}
            ! Aerodynamic roughness per land use type - realistic values
            do k = 1, size(met_state%FRZ0, 3)  ! nlanduse types
               if (k == 1) then
                  met_state%FRZ0(i,j,k) = 0.05_fp     ! Grassland/crop roughness [m]
               else if (k == 2) then
                  met_state%FRZ0(i,j,k) = 1.2_fp      ! Forest roughness [m]
               else if (k == 3) then
                  met_state%FRZ0(i,j,k) = 0.8_fp      ! Urban roughness [m]
               else if (k <= 5) then
                  met_state%FRZ0(i,j,k) = 0.02_fp     ! Wetland/water roughness [m]
               else
                  met_state%FRZ0(i,j,k) = 0.001_fp    ! Bare ground roughness [m]
               end if
            end do
{%- set sep.value = '\n            ' %}{%- endif %}

         end do
      end do
{% endif %}

{% if required_met_fields and ('SALINITY' in required_met_fields or 'LUCNAME' in required_met_fields) %}
      ! Set scalar meteorological variables
{% if required_met_fields and 'SALINITY' in required_met_fields %}
      met_state%SALINITY = 35.0_fp                                 ! Ocean salinity [psu]
{% endif %}
{% if required_met_fields and 'LUCNAME' in required_met_fields %}
      met_state%LUCNAME = 'NOAH'                                  ! Land use category name
{% endif %}
{% endif %}

{% if config.process_type == "emission" %}
      ! Set up DELP (pressure difference between levels) for emission unit conversion
      ! DELP is only used for unit conversion in emission processes
      do j = 1, ny
         do i = 1, nx
            do k = 1, nz
               ! Set realistic pressure differences (Pa) for atmospheric layers
               ! Surface layers have higher DELP, upper levels have lower DELP
               altitude_km = real(k-1, fp) * 20.0_fp / real(nz-1, fp)  ! 0-20 km altitude
               met_state%DELP(i,j,k) = 10000.0_fp * exp(-altitude_km / 8.0_fp)  ! Exponential pressure decrease
            end do
         end do
      end do
{% endif %}

   end subroutine setup_met

{% if config.schemes %}
   !> Test a specific {{ config.name }} scheme with comprehensive validation
   subroutine test_scheme(core_arg, scheme_name, rc_arg)
      type(CATChemCoreType), intent(inout) :: core_arg
      character(len=*), intent(in) :: scheme_name
      integer, intent(out) :: rc_arg
      
      type(ProcessManagerType), pointer :: process_mgr
      type(StateManagerType), pointer :: state_mgr
      type(Process{{ config.class_name }}Interface), pointer :: {{ config.name }}_interface
      type(ConfigManagerType), pointer :: config_mgr
      type(ErrorManagerType), pointer :: error_mgr
      
      rc_arg = CC_SUCCESS
      
      ! Get process manager and state manager
      process_mgr => core_arg%get_process_manager()
      state_mgr => core_arg%get_state_manager()
      
      ! Get {{ config.name }} process interface
      {{ config.name }}_interface => null()
      select type(process => process_mgr%processes(1))
      type is (Process{{ config.class_name }}Interface)
         {{ config.name }}_interface => process
      end select
      
      if (.not. associated({{ config.name }}_interface)) then
         rc_arg = CC_FAILURE
         return
      end if
      
{% if config.process_type == "emission" %}
      ! Step 1: Set the timestep for emission calculations
      call {{ config.name }}_interface%set_timestep(dt)
      
      ! Step 2: Set the scheme
{% else %}
      ! Step 1: Set the scheme
{% endif %}
{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! For gas/aerosol differentiated processes, determine scheme type
      select case (trim(scheme_name))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
{% if scheme.gas_or_aero == 'gas' %}
         call {{ config.name }}_interface%set_scheme(scheme_name, gas_scheme=.true.)
{% elif scheme.gas_or_aero == 'aero' %}
         call {{ config.name }}_interface%set_scheme(scheme_name, gas_scheme=.false.)
{% else %}
         call {{ config.name }}_interface%set_scheme(scheme_name)
{% endif %}
{% endfor %}
      case default
         call {{ config.name }}_interface%set_scheme(scheme_name)
      end select
{% else %}
      call {{ config.name }}_interface%set_scheme(scheme_name)
{% endif %}
      
{% if config.process_type == "emission" %}
      ! Step 3: Reload scheme-specific configuration
{% else %}
      ! Step 2: Reload scheme-specific configuration
{% endif %}
      config_mgr => state_mgr%get_config_ptr()
      error_mgr => state_mgr%get_error_manager()
      
      if (.not. associated(config_mgr)) then
         call error_mgr%report_error(1003, &
                                    'ConfigManager not available from StateManager', rc_arg)
         return
      end if
      
      if (.not. associated(error_mgr)) then
         rc_arg = CC_FAILURE
         return
      end if
      
      ! Call the scheme-specific loading function directly
      select case (trim(scheme_name))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
         call {{ config.name }}_interface%process_config%load_{{ scheme.name }}_config(config_mgr, error_mgr)
{% endfor %}
      case default
         call error_mgr%report_error(1004, &
                                    'Unknown scheme: ' // trim(scheme_name), rc_arg)
         return
      end select

{% if config.process_behavior and config.process_behavior.gas_aero_differentiation %}
      ! Validate gas/aerosol species compatibility
      select case (trim(scheme_name))
{% for scheme in config.schemes %}
      case ('{{ scheme.name }}')
{% if scheme.gas_or_aero == 'gas' %}
         ! {{ scheme.class_name }} scheme should handle gas species
         ! Validation: Check that gas species filtering works correctly
{% elif scheme.gas_or_aero == 'aero' %}
         ! {{ scheme.class_name }} scheme should handle aerosol species  
         ! Validation: Check that aerosol species filtering works correctly
{% else %}
         ! {{ scheme.class_name }} scheme handles both gas and aerosol species
{% endif %}
{% endfor %}
      end select
{% endif %}
      
{% if config.process_type == "emission" %}
      ! Step 4: Reset diagnostics for the new scheme
      call reset_diagnostics_for_scheme({{ config.name }}_interface, state_mgr, scheme_name, rc_arg)
      if (rc_arg /= CC_SUCCESS) return
      
      ! Step 5: Run the process to populate diagnostic data
      call process_mgr%run_column_processes(state_mgr, rc_arg)
      if (rc_arg /= CC_SUCCESS) return
      
      ! Step 6: Validate all results
{% else %}
      ! Step 3: Reset diagnostics for the new scheme
      call reset_diagnostics_for_scheme({{ config.name }}_interface, state_mgr, scheme_name, rc_arg)
      if (rc_arg /= CC_SUCCESS) return
      
      ! Step 4: Run the process to populate diagnostic data
      call process_mgr%run_column_processes(state_mgr, rc_arg)
      if (rc_arg /= CC_SUCCESS) return
      
      ! Step 5: Validate all results
{% endif %}
      call validate_results(core_arg, rc_arg)
      
   end subroutine test_scheme

   !> Reset diagnostics for a specific scheme (test-specific function)
   !! This function handles diagnostic reset when switching between schemes during testing
   subroutine reset_diagnostics_for_scheme({{ config.name }}_interface, container, scheme_name, rc_arg)
      type(Process{{ config.class_name }}Interface), intent(inout) :: {{ config.name }}_interface
      type(StateManagerType), intent(inout) :: container
      character(len=*), intent(in) :: scheme_name
      integer, intent(out) :: rc_arg
      
      type(DiagnosticManagerType), pointer :: diag_mgr
      type(ErrorManagerType), pointer :: error_mgr
      character(len=64) :: current_scheme
      
      rc_arg = CC_SUCCESS
      
      ! Get managers
      diag_mgr => container%get_diagnostic_manager()
      error_mgr => container%get_error_manager()
      
      ! Get current scheme
      current_scheme = {{ config.name }}_interface%get_scheme()
      
      ! Remove existing process registration (this clears all diagnostic fields)
      call diag_mgr%remove_process('{{ config.name }}', rc_arg)
      if (rc_arg /= CC_SUCCESS) then
         call error_mgr%report_error(ERROR_UNSUPPORTED_OPERATION, &
                                   'Failed to remove existing diagnostics for {{ config.name }} process', rc_arg)
         ! Continue anyway - this might be the first registration
         rc_arg = CC_SUCCESS
      endif
      
      ! Re-register diagnostics for the new scheme
      ! The scheme-specific configuration should already be set correctly
      call {{ config.name }}_interface%register_diagnostics(container, rc_arg)
      if (rc_arg /= CC_SUCCESS) then
         call error_mgr%report_error(ERROR_UNSUPPORTED_OPERATION, &
                                   'Failed to re-register diagnostics for scheme: ' // &
                                   trim(current_scheme), rc_arg)
         return
      endif
      
   end subroutine reset_diagnostics_for_scheme
{% endif %}

   !> Validate the results of the integration test with comprehensive diagnostic checking
   subroutine validate_results(core_arg, rc_arg)
      type(CATChemCoreType), intent(inout) :: core_arg
      integer, intent(out) :: rc_arg
      
      type(DiagnosticManagerType), pointer :: diag_mgr
      type(DiagnosticRegistryType), pointer :: {{ config.name }}_registry
      character(len=64), allocatable :: field_names(:)
      integer :: num_fields, i, local_rc, data_type
      real(fp) :: scalar_value
      real(fp), pointer :: array_1d_ptr(:) => null()
      real(fp), pointer :: array_2d_ptr(:,:) => null()
      real(fp), pointer :: array_3d_ptr(:,:,:) => null()
      logical :: validation_passed
      character(len=64) :: field_name
      character(len=20) :: type_name
      
      rc_arg = CC_SUCCESS
      validation_passed = .true.
      
      write(output_unit,'(A)') '  Validating {{ config.name }} emission results...'
      
      ! Use core validation first
      if (.not. core_arg%validate()) then
         write(error_unit,'(A)') '  ERROR: Core validation failed'
         rc_arg = CC_FAILURE
         return
      end if
      write(output_unit,'(A)') '    ✓ Core validation passed'
      
      ! Get DiagnosticManager from core
      diag_mgr => core_arg%get_diagnostic_manager()
      if (.not. associated(diag_mgr)) then
         write(error_unit,'(A)') '  ERROR: Could not get DiagnosticManager from core'
         rc_arg = CC_FAILURE
         return
      end if
      
      ! Get the {{ config.name }} process diagnostic registry
      call diag_mgr%get_process_registry('{{ config.name }}', {{ config.name }}_registry, local_rc)
      if (local_rc /= CC_SUCCESS .or. .not. associated({{ config.name }}_registry)) then
         write(error_unit,'(A)') '  ERROR: Could not get {{ config.name }} process registry'
         rc_arg = CC_FAILURE
         return
      end if
      
      ! Get the number of registered diagnostic fields
      num_fields = {{ config.name }}_registry%get_field_count()
      write(output_unit,'(A,I0,A)') '    Found ', num_fields, ' registered diagnostic fields for {{ config.name }} process'
      
      if (num_fields == 0) then
         write(error_unit,'(A)') '  ERROR: No diagnostic fields registered for {{ config.name }} process'
         rc_arg = CC_FAILURE
         return
      end if
      
      ! Allocate array for field names
      allocate(field_names(num_fields))
      
      ! Get all field names
      call {{ config.name }}_registry%list_fields(field_names, num_fields)
      
      ! Iterate through all diagnostic fields and validate them
      write(output_unit,'(A)') '    Validating all registered diagnostic fields:'
      
      do i = 1, num_fields
         field_name = trim(field_names(i))
         write(output_unit,'(A,I0,A,A)') '      Field ', i, ': ', trim(field_name)
         
         ! Get field values and type information directly from DiagnosticManager
         call diag_mgr%get_field_value('{{ config.name }}', field_name, &
                                     scalar_value=scalar_value, &
                                     array_1d_ptr=array_1d_ptr, &
                                     array_2d_ptr=array_2d_ptr, &
                                     array_3d_ptr=array_3d_ptr, &
                                     data_type=data_type, &
                                     rc=local_rc)
         if (local_rc /= CC_SUCCESS) then
            write(error_unit,'(A,A)') '    WARNING: Could not retrieve field value: ', trim(field_name)
            validation_passed = .false.
            cycle
         end if
         
         ! Convert data type to readable name and validate values
         call validate_field_by_type(field_name, data_type, scalar_value, &
                                   array_1d_ptr, array_2d_ptr, array_3d_ptr, validation_passed, verbose=.false.)
         
      end do
      
      ! Clean up
      deallocate(field_names)
      
      ! Final validation result
      if (.not. validation_passed) then
         write(error_unit,'(A)') '  VALIDATION FAILED: Some {{ config.name }} diagnostics failed validation'
         rc_arg = CC_FAILURE
      else
         write(output_unit,'(A)') '  ✓ All {{ config.name }} diagnostic validations passed'
         write(output_unit,'(A,I0,A)') '    - ', num_fields, ' diagnostic fields validated'
         write(output_unit,'(A)') '    - All emission values are positive'
         write(output_unit,'(A)') '    - Diagnostic system is functioning correctly'
      end if
      
   end subroutine validate_results

   !> Validate field values based on type and emission expectations
   subroutine validate_field_by_type(field_name, data_type, scalar_value, &
                                    array_1d_ptr, array_2d_ptr, array_3d_ptr, validation_passed, verbose)
      character(len=*), intent(in) :: field_name
      integer, intent(in) :: data_type
      real(fp), intent(in) :: scalar_value
      real(fp), pointer, intent(in) :: array_1d_ptr(:)
      real(fp), pointer, intent(in) :: array_2d_ptr(:,:)
      real(fp), pointer, intent(in) :: array_3d_ptr(:,:,:)
      logical, intent(inout) :: validation_passed
      logical, intent(in), optional :: verbose
      
      logical :: field_passed
      logical :: is_verbose = .false.
      character(len=20) :: type_name
      integer :: i, j, k
      real(fp) :: current_value
      
      ! Set verbose mode
      if (present(verbose)) is_verbose = verbose
      ! Explicitly initialize field_passed for each call
      field_passed = .true.
      
      ! Convert data type to readable name and validate values
      select case (data_type)
      case (DIAG_REAL_SCALAR)
         type_name = 'Real Scalar'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         write(output_unit,'(A,E12.5)') '        Scalar value: ', scalar_value
         if (is_verbose) then
            write(output_unit,'(A,A,A,E12.5)') '          ', trim(field_name), ' = ', scalar_value
         end if
         
         ! Check if scalar value is finite and non-negative
         if (scalar_value /= scalar_value) then  ! NaN check
            write(error_unit,'(A,A)') '    ERROR: Field has NaN value: ', trim(field_name)
            field_passed = .false.
         else if (scalar_value < 0.0_fp) then
            write(error_unit,'(A,A)') '    ERROR: Field has negative value: ', trim(field_name)
            field_passed = .false.
         else if (.not. (scalar_value < huge(scalar_value))) then  ! Infinite check
            write(error_unit,'(A,A)') '    ERROR: Field has infinite value: ', trim(field_name)
            field_passed = .false.
         else
            write(output_unit,'(A,A)') '        ✓ Field has valid finite non-negative value: ', trim(field_name)
         end if
         
      case (DIAG_REAL_1D)
         type_name = 'Real 1D Array'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         if (associated(array_1d_ptr)) then
            write(output_unit,'(A,I0)') '        Array size: ', size(array_1d_ptr)
            
            ! Check each element in the 1D array
            do i = 1, size(array_1d_ptr)
               current_value = array_1d_ptr(i)
               if (is_verbose) then
                  write(output_unit,'(A,A,A,I0,A,E12.5)') '          ', trim(field_name), '[', i, '] = ', current_value
               end if
               if (current_value /= current_value) then  ! NaN check
                  write(error_unit,'(A,A,A,I0,A)') '    ERROR: Field has NaN at index ', trim(field_name), ' (', i, ')'
                  field_passed = .false.
                  exit
               else if (current_value < 0.0_fp) then
                  write(error_unit,'(A,A,A,I0,A)') '    ERROR: Field has negative value at index ', trim(field_name), ' (', i, ')'
                  field_passed = .false.
                  exit
               else if (.not. (current_value < huge(current_value))) then  ! Infinite check
                  write(error_unit,'(A,A,A,I0,A)') '    ERROR: Field has infinite value at index ', trim(field_name), ' (', i, ')'
                  field_passed = .false.
                  exit
               end if
            end do
            
            if (field_passed) then
               ! Check if sum of array is zero
               if (sum(array_1d_ptr) == 0.0_fp) then
                  write(error_unit,'(A,A)') '    WARNING: Field has zero sum (all elements are zero): ', trim(field_name)
                  !field_passed = .false.
               else
                  write(output_unit,'(A,A)') '        ✓ All array elements are finite and non-negative: ', trim(field_name)
               end if
            end if
         else
            write(error_unit,'(A,A)') '    ERROR: 1D array not associated for field: ', trim(field_name)
            field_passed = .false.
         end if
         
      case (DIAG_REAL_2D)
         type_name = 'Real 2D Array'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         if (associated(array_2d_ptr)) then
            write(output_unit,'(A,I0,A,I0)') '        Array size: ', size(array_2d_ptr,1), ' x ', size(array_2d_ptr,2)
            
            ! Check each element in the 2D array
            outer_loop_2d: do j = 1, size(array_2d_ptr,2)
               do i = 1, size(array_2d_ptr,1)
                  current_value = array_2d_ptr(i,j)
                  if (is_verbose) then
                     write(output_unit,'(A,A,A,I0,A,I0,A,E12.5)') '          ', trim(field_name), '[', i, ',', j, '] = ', current_value
                  end if
                  if (current_value /= current_value) then  ! NaN check
                     write(error_unit,'(A,A,A,I0,A,I0,A)') '    ERROR: Field has NaN at index ', trim(field_name), ' (', i, ',', j, ')'
                     field_passed = .false.
                     exit outer_loop_2d
                  else if (current_value < 0.0_fp) then
                     write(error_unit,'(A,A,A,I0,A,I0,A)') '    ERROR: Field has negative value at index ', trim(field_name), ' (', i, ',', j, ')'
                     field_passed = .false.
                     exit outer_loop_2d
                  else if (.not. (current_value < huge(current_value))) then  ! Infinite check
                     write(error_unit,'(A,A,A,I0,A,I0,A)') '    ERROR: Field has infinite value at index ', trim(field_name), ' (', i, ',', j, ')'
                     field_passed = .false.
                     exit outer_loop_2d
                  end if
               end do
            end do outer_loop_2d
            
            if (field_passed) then
               ! Check if sum of array is zero
               if (sum(array_2d_ptr) == 0.0_fp) then
                  write(error_unit,'(A,A)') '    WARNING: Field has zero sum (all elements are zero): ', trim(field_name)
                  !field_passed = .false.
               else
                  write(output_unit,'(A,A)') '        ✓ All array elements are finite and non-negative: ', trim(field_name)
               end if
            end if
         else
            write(error_unit,'(A,A)') '    ERROR: 2D array not associated for field: ', trim(field_name)
            field_passed = .false.
         end if
         
      case (DIAG_REAL_3D)
         type_name = 'Real 3D Array'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         if (associated(array_3d_ptr)) then
            write(output_unit,'(A,I0,A,I0,A,I0)') '        Array size: ', size(array_3d_ptr,1), ' x ', size(array_3d_ptr,2), ' x ', size(array_3d_ptr,3)
            
            ! Check each element in the 3D array
            outer_loop_3d: do k = 1, size(array_3d_ptr,3)
               do j = 1, size(array_3d_ptr,2)
                  do i = 1, size(array_3d_ptr,1)
                     current_value = array_3d_ptr(i,j,k)
                     if (is_verbose) then
                        write(output_unit,'(A,A,A,I0,A,I0,A,I0,A,E12.5)') '          ', trim(field_name), '[', i, ',', j, ',', k, '] = ', current_value
                     end if
                     if (current_value /= current_value) then  ! NaN check
                        write(error_unit,'(A,A,A,I0,A,I0,A,I0,A)') '    ERROR: Field has NaN at index ', trim(field_name), ' (', i, ',', j, ',', k, ')'
                        field_passed = .false.
                        exit outer_loop_3d
                     else if (current_value < 0.0_fp) then
                        write(error_unit,'(A,A,A,I0,A,I0,A,I0,A)') '    ERROR: Field has negative value at index ', trim(field_name), ' (', i, ',', j, ',', k, ')'
                        field_passed = .false.
                        exit outer_loop_3d
                     else if (.not. (current_value < huge(current_value))) then  ! Infinite check
                        write(error_unit,'(A,A,A,I0,A,I0,A,I0,A)') '    ERROR: Field has infinite value at index ', trim(field_name), ' (', i, ',', j, ',', k, ')'
                        field_passed = .false.
                        exit outer_loop_3d
                     end if
                  end do
               end do
            end do outer_loop_3d
            
            if (field_passed) then
               ! Check if sum of array is zero
               if (sum(array_3d_ptr) == 0.0_fp) then
                  write(error_unit,'(A,A)') '    WARNING: Field has zero sum (all elements are zero): ', trim(field_name)
                  !field_passed = .false.
               else
                  write(output_unit,'(A,A)') '        ✓ All array elements are finite and non-negative: ', trim(field_name)
               end if
            end if
         else
            write(error_unit,'(A,A)') '    ERROR: 3D array not associated for field: ', trim(field_name)
            field_passed = .false.
         end if
         
      case (DIAG_INTEGER_SCALAR)
         type_name = 'Integer Scalar'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         write(output_unit,'(A,E12.5)') '        Scalar value: ', scalar_value
         if (is_verbose) then
            write(output_unit,'(A,A,A,E12.5)') '          ', trim(field_name), ' = ', scalar_value
         end if
         
         ! For integer scalar, just check if it's non-negative
         if (scalar_value < 0.0_fp) then
            write(error_unit,'(A,A)') '    ERROR: Integer field has negative value: ', trim(field_name)
            field_passed = .false.
         else
            write(output_unit,'(A,A)') '        ✓ Integer field has non-negative value: ', trim(field_name)
         end if
         
      case (DIAG_INTEGER_1D)
         type_name = 'Integer 1D Array'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         if (associated(array_1d_ptr)) then
            write(output_unit,'(A,I0)') '        Array size: ', size(array_1d_ptr)
            
            ! Check each element in the 1D integer array
            do i = 1, size(array_1d_ptr)
               current_value = array_1d_ptr(i)
               if (is_verbose) then
                  write(output_unit,'(A,A,A,I0,A,E12.5)') '          ', trim(field_name), '[', i, '] = ', current_value
               end if
               if (current_value /= current_value) then  ! NaN check
                  write(error_unit,'(A,A,A,I0,A)') '    ERROR: Integer field has NaN at index ', trim(field_name), ' (', i, ')'
                  field_passed = .false.
                  exit
               else if (current_value < 0.0_fp) then
                  write(error_unit,'(A,A,A,I0,A)') '    ERROR: Integer field has negative value at index ', trim(field_name), ' (', i, ')'
                  field_passed = .false.
                  exit
               end if
            end do
            
            if (field_passed) then
               ! Check if sum of array is zero
               if (sum(array_1d_ptr) == 0.0_fp) then
                  write(error_unit,'(A,A)') '    WARNING: Integer field has zero sum (all elements are zero): ', trim(field_name)
                  !field_passed = .false.
               else
                  write(output_unit,'(A,A)') '        ✓ All integer array elements are non-negative: ', trim(field_name)
               end if
            end if
         else
            write(error_unit,'(A,A)') '    ERROR: 1D integer array not associated for field: ', trim(field_name)
            field_passed = .false.
         end if
         
      case (DIAG_INTEGER_2D)
         type_name = 'Integer 2D Array'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         if (associated(array_2d_ptr)) then
            write(output_unit,'(A,I0,A,I0)') '        Array size: ', size(array_2d_ptr,1), ' x ', size(array_2d_ptr,2)
            
            ! Check each element in the 2D integer array
            outer_loop_int_2d: do j = 1, size(array_2d_ptr,2)
               do i = 1, size(array_2d_ptr,1)
                  current_value = array_2d_ptr(i,j)
                  if (is_verbose) then
                     write(output_unit,'(A,A,A,I0,A,I0,A,E12.5)') '          ', trim(field_name), '[', i, ',', j, '] = ', current_value
                  end if
                  if (current_value /= current_value) then  ! NaN check
                     write(error_unit,'(A,A,A,I0,A,I0,A)') '    ERROR: Integer field has NaN at index ', trim(field_name), ' (', i, ',', j, ')'
                     field_passed = .false.
                     exit outer_loop_int_2d
                  else if (current_value < 0.0_fp) then
                     write(error_unit,'(A,A,A,I0,A,I0,A)') '    ERROR: Integer field has negative value at index ', trim(field_name), ' (', i, ',', j, ')'
                     field_passed = .false.
                     exit outer_loop_int_2d
                  end if
               end do
            end do outer_loop_int_2d
            
            if (field_passed) then
               ! Check if sum of array is zero
               if (sum(array_2d_ptr) == 0.0_fp) then
                  write(error_unit,'(A,A)') '    WARNING: Integer field has zero sum (all elements are zero): ', trim(field_name)
                  !field_passed = .false.
               else
                  write(output_unit,'(A,A)') '        ✓ All integer array elements are non-negative: ', trim(field_name)
               end if
            end if
         else
            write(error_unit,'(A,A)') '    ERROR: 2D integer array not associated for field: ', trim(field_name)
            field_passed = .false.
         end if
         
      case (DIAG_INTEGER_3D)
         type_name = 'Integer 3D Array'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         if (associated(array_3d_ptr)) then
            write(output_unit,'(A,I0,A,I0,A,I0)') '        Array size: ', size(array_3d_ptr,1), ' x ', size(array_3d_ptr,2), ' x ', size(array_3d_ptr,3)
            
            ! Check each element in the 3D integer array
            outer_loop_int_3d: do k = 1, size(array_3d_ptr,3)
               do j = 1, size(array_3d_ptr,2)
                  do i = 1, size(array_3d_ptr,1)
                     current_value = array_3d_ptr(i,j,k)
                     if (is_verbose) then
                        write(output_unit,'(A,A,A,I0,A,I0,A,I0,A,E12.5)') '          ', trim(field_name), '[', i, ',', j, ',', k, '] = ', current_value
                     end if
                     if (current_value /= current_value) then  ! NaN check
                        write(error_unit,'(A,A,A,I0,A,I0,A,I0,A)') '    ERROR: Integer field has NaN at index ', trim(field_name), ' (', i, ',', j, ',', k, ')'
                        field_passed = .false.
                        exit outer_loop_int_3d
                     else if (current_value < 0.0_fp) then
                        write(error_unit,'(A,A,A,I0,A,I0,A,I0,A)') '    ERROR: Integer field has negative value at index ', trim(field_name), ' (', i, ',', j, ',', k, ')'
                        field_passed = .false.
                        exit outer_loop_int_3d
                     end if
                  end do
               end do
            end do outer_loop_int_3d
            
            if (field_passed) then
               ! Check if sum of array is zero
               if (sum(array_3d_ptr) == 0.0_fp) then
                  write(error_unit,'(A,A)') '    WARNING: Integer field has zero sum (all elements are zero): ', trim(field_name)
                  !field_passed = .false.
               else
                  write(output_unit,'(A,A)') '        ✓ All integer array elements are non-negative: ', trim(field_name)
               end if
            end if
         else
            write(error_unit,'(A,A)') '    ERROR: 3D integer array not associated for field: ', trim(field_name)
            field_passed = .false.
         end if
         
      case default
         type_name = 'Unknown Type'
         write(output_unit,'(A,A)') '        Type: ', trim(type_name)
         write(error_unit,'(A,A)') '    ERROR: Unsupported data type for field: ', trim(field_name)
         field_passed = .false.
         return
      end select
      
      ! Update overall validation status
      if (.not. field_passed) then
         validation_passed = .false.
      end if
      
   end subroutine validate_field_by_type

end program test_{{ config.name }}_integration
