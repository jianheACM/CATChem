# Makefile for AQMIO 3D test
# Francis Poulin - October 2025

# ESMF installation paths
ESMF_ROOT = /opt/homebrew/Cellar/esmf/8.8.0
ESMF_MODDIR = $(ESMF_ROOT)/mod/modO/Darwin.gfortran.64.openmpi.default
ESMF_LIBDIR = $(ESMF_ROOT)/lib/libO/Darwin.gfortran.64.openmpi.default

# NetCDF paths (from pkg-config)
NETCDF_FFLAGS = -I/opt/homebrew/Cellar/netcdf-fortran/4.6.1_1/include -I/opt/homebrew/Cellar/netcdf/4.9.2_2/include
NETCDF_LIBS = -L/opt/homebrew/Cellar/netcdf-fortran/4.6.1_1/lib -lnetcdff

# MPI (OpenMPI via Homebrew)
MPI_ROOT = /opt/homebrew/Cellar/open-mpi/5.0.8
MPI_FFLAGS = -I$(MPI_ROOT)/include
MPI_LIBS = -L$(MPI_ROOT)/lib -lmpi_usempif08 -lmpi_usempi_ignore_tkr -lmpi_mpifh -lmpi

# Compiler and flags
FC = mpifort
FFLAGS = -g -O2 
FFLAGS += -I$(ESMF_MODDIR) $(NETCDF_FFLAGS)
FFLAGS += -DHAVE_NETCDF=1

# Libraries
LIBS = -L$(ESMF_LIBDIR) -lesmf $(NETCDF_LIBS)

# Source files
SRCS = aqmio.F90 test_aqmio_3d.F90
OBJS = $(SRCS:.F90=.o)
TARGET = test_aqmio_3d

# Default target
all: $(TARGET)

# Build the test executable
$(TARGET): $(OBJS)
	$(FC) $(FFLAGS) -o $@ $(OBJS) $(LIBS)

# Compile AQMIO module first
aqmio.o: drivers/nuopc/aqmio.F90
	$(FC) $(FFLAGS) -c $< -o $@

# Compile test program (depends on AQMIO module)
test_aqmio_3d.o: test_aqmio_3d.F90 aqmio.o
	$(FC) $(FFLAGS) -c $< -o $@

# Clean up
clean:
	rm -f *.o *.mod $(TARGET) *.nc

# Show compilation flags (for debugging)
debug:
	@echo "FC = $(FC)"
	@echo "FFLAGS = $(FFLAGS)"
	@echo "LIBS = $(LIBS)"
	@echo "ESMF_MODDIR = $(ESMF_MODDIR)"
	@echo "ESMF_LIBDIR = $(ESMF_LIBDIR)"

.PHONY: all clean debug