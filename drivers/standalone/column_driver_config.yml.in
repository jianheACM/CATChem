# CATChem Standalone Column Driver Configuration
# This configuration file is specifically designed for the column driver
# demonstrating modern API capabilities

simulation:
  name: "standalone_column"
  description: "Single column atmospheric chemistry simulation"
  start_date: 20250101 0000
  end_date: 20250101 2300
  species_filename: "CATChem_species.yml"

  # Column-specific settings
  column_mode: true
  location:
    latitude: 40.0    # Degrees North
    longitude: -75.0  # Degrees West (Eastern US)
    site_name: "Eastern_US_Test"

# Grid configuration
grid:
  number_of_levels: 72
  level_type: "pressure"  # pressure or height
  top_pressure: 1000.0    # Pa (10 hPa)
  surface_pressure: 101325.0  # Pa (1013.25 hPa)

# Time stepping
timesteps:
  physics_timestep_in_s: 3600      # 1 hour
  chemistry_timestep_in_s: 3600    # 1 hour
  total_steps: 24                  # 24-hour simulation

# Process configuration with run phases
process:
  # Run phase configuration
  enable_run_phases: true
  run_phases:
    - name: "emissions"
      description: "Emission processes"
      frequency: "every_timestep"
      processes: ["dust", "seasalt", "externalemission"]

    - name: "chemistry"
      description: "Chemical transformations"
      frequency: "every_timestep"
      processes: ["chemistry", "photolysis"]

    - name: "transport"
      description: "Transport processes"
      frequency: "every_timestep"
      processes: ["advection", "diffusion", "convection"]

    - name: "deposition"
      description: "Deposition processes"
      frequency: "every_timestep"
      processes: ["drydep", "wetdep"]

  # Individual process settings
  dust:
    activate: true
    scheme_opt: 1
    dust_drag_opt: 1
    dust_moist_opt: 1
    dust_horizflux_opt: 1
    dust_alpha: 1.0
    dust_beta: 1.0

  seasalt:
    activate: true
    scheme_opt: 3
    scale_factor: 1.0
    weibull: true

  drydep:
    activate: true
    scheme_opt: 1
    resuspension: false

  externalemission:
    activate: true
    config_file: "external_emission_config.yaml"

  chemistry:
    activate: false  # Placeholder - not implemented in column driver
    mechanism: "CB6"

  photolysis:
    activate: false  # Placeholder

  wetdep:
    activate: false  # Placeholder

# Performance options
performance:
  column_processing: true
  column_batching: true
  max_processes: 20
  enable_openmp: false
  num_threads: 1

# Diagnostic and output settings
diagnostics:
  enable: true
  output_frequency: 6  # Output every 6 hours

  # Process-level diagnostics
  process_diagnostics:
    dust:
      - "emission_flux"
      - "total_emissions"
    drydep:
      - "deposition_velocity"
      - "deposition_flux"
    seasalt:
      - "emission_flux"

  # Column diagnostics
  column_diagnostics:
    - "concentration_profiles"
    - "temperature_profile"
    - "pressure_profile"
    - "wind_profiles"

# Meteorology configuration
meteorology:
  # Initial conditions
  surface_temperature: 288.15  # K
  temperature_lapse_rate: 0.0065  # K/m
  surface_pressure: 101325.0  # Pa
  relative_humidity: 0.70     # Fraction

  # Simple diurnal cycles
  diurnal_cycles:
    temperature:
      enable: true
      amplitude: 5.0  # K
      phase_shift: 6.0  # Hours (peak at noon)

    emissions:
      enable: true
      amplitude: 1.0
      phase_shift: 6.0  # Peak during day

  # Background wind
  wind:
    u_component: 10.0  # m/s
    v_component: 5.0   # m/s
    height_dependence: true

# Output configuration
output:
  format: "text"  # For demo (would be NetCDF in real implementation)
  filename_template: "column_output_@NSTEPS@steps"

  # Variables to output
  variables:
    - "concentrations"
    - "temperature"
    - "pressure"
    - "wind_u"
    - "wind_v"
    - "emission_rates"
    - "diagnostics"

# Logging and debugging
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR
  file: "column_driver.log"
  console_output: true

debug:
  enable_timing: true
  phase_timing: true
  memory_tracking: false
  detailed_diagnostics: false
