  units = index
  dimensions = ()
  type = integer
  intent = in
[aer_ra_frq_in]
  standard_name = catchem_aer_ra_frq
  long_name = catchem aer radiation frequency
  units = index
  dimensions = ()
  type = integer
  intent = in
# Precipitation <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
[rainc_cpl]
  standard_name = cumulative_lwe_thickness_of_convective_precipitation_amount_for_coupling
