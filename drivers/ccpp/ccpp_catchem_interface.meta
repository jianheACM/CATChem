  units = m
  dimensions = (horizontal_loop_extent)
  type = real
  kind = kind_phys
  intent = in
[rain_cplchm]
  standard_name = lwe_thickness_of_precipitation_amount_for_chemcoupling
  long_name = total rain precipitation chem
  units = m
  dimensions = (horizontal_loop_extent)
  type = real
  kind = kind_phys
  intent = in
[cldf]
  standard_name = cloud_area_fraction
