[nirdfdi]
  standard_name = surface_downwelling_diffuse_nir_shortwave_flux_on_radiation_timestep
  long_name = sfc nir diff sw downward flux
  units = W m-2
  dimensions = (horizontal_loop_extent)
  type = real
  kind = kind_phys
