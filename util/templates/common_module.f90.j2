contains

{% if process_type == 'emission' %}
   !> \brief Calculate wind threshold velocity
   !! \param[in] particle_diameter Particle diameter [μm]
   !! \param[in] particle_density Particle density [kg/m³]
   !! \param[in] air_density Air density [kg/m³]
   !! \return Threshold velocity [m/s]
   pure function calculate_wind_threshold(particle_diameter, particle_density, air_density) result(u_threshold)
      real(fp), intent(in) :: particle_diameter, particle_density, air_density
      real(fp) :: u_threshold

      ! Simple threshold calculation - would implement proper formulation
      u_threshold = 0.2_fp * sqrt(particle_diameter * 1.0e-6_fp)
   end function calculate_wind_threshold

   !> \brief Calculate saltation flux
   !! \param[in] wind_speed Wind speed [m/s]
   !! \param[in] threshold_speed Threshold wind speed [m/s]
   !! \return Saltation flux [kg/m²/s]
   pure function calculate_saltation_flux(wind_speed, threshold_speed) result(flux)
      real(fp), intent(in) :: wind_speed, threshold_speed
      real(fp) :: flux

      if (wind_speed > threshold_speed) then
         flux = (wind_speed - threshold_speed)**3
      else
         flux = 0.0_fp
      end if
   end function calculate_saltation_flux

   !> \brief Apply size distribution to total flux
   !! \param[in] total_flux Total emission flux [kg/m²/s]
   !! \param[in] size_fractions Size distribution fractions [dimensionless]
   !! \param[out] size_fluxes Flux per size bin [kg/m²/s]
   pure subroutine apply_size_distribution(total_flux, size_fractions, size_fluxes)
      real(fp), intent(in) :: total_flux
      real(fp), intent(in) :: size_fractions(:)
      real(fp), intent(out) :: size_fluxes(:)

      integer :: i

      do i = 1, size(size_fractions)
         size_fluxes(i) = total_flux * size_fractions(i)
      end do
   end subroutine apply_size_distribution

{% elif process_type == 'multiphase_chemistry' %}
   !> \brief Calculate temperature-dependent reaction rates
   !! \param[in] rate_298 Rate constant at 298K [varies by reaction]
   !! \param[in] activation_energy Activation energy [J/mol]
   !! \param[in] temperature Temperature [K]
   !! \return Temperature-corrected rate constant
   pure function calculate_reaction_rates(rate_298, activation_energy, temperature) result(rate)
      real(fp), intent(in) :: rate_298, activation_energy, temperature
      real(fp) :: rate

      ! Arrhenius equation
      rate = rate_298 * exp(-activation_energy / R_GAS * (1.0_fp/temperature - 1.0_fp/T_REF))
   end function calculate_reaction_rates

   !> \brief Apply temperature correction to rates
   !! \param[inout] rates Array of reaction rates
   !! \param[in] temperature Temperature [K]
   pure subroutine apply_temperature_correction(rates, temperature)
      real(fp), intent(inout) :: rates(:)
      real(fp), intent(in) :: temperature

      real(fp) :: temp_factor
      integer :: i

      temp_factor = T_REF / temperature

      do i = 1, size(rates)
         rates(i) = rates(i) * temp_factor
      end do
   end subroutine apply_temperature_correction

   !> \brief Check species concentration bounds
   !! \param[inout] concentrations Species concentrations
   !! \param[in] min_conc Minimum allowed concentration
   pure subroutine check_species_bounds(concentrations, min_conc)
      real(fp), intent(inout) :: concentrations(:)
      real(fp), intent(in) :: min_conc

      integer :: i

      do i = 1, size(concentrations)
         concentrations(i) = max(concentrations(i), min_conc)
      end do
   end subroutine check_species_bounds

{% elif process_type == 'aqueous_chemistry' %}
   !> \brief Calculate Henry's law constant
   !! \param[in] henry_298 Henry constant at 298K [M/atm]
   !! \param[in] d_sol_h Enthalpy of dissolution [J/mol]
   !! \param[in] temperature Temperature [K]
   !! \return Temperature-dependent Henry constant [M/atm]
   pure function calculate_henry_constant(henry_298, d_sol_h, temperature) result(henry)
      real(fp), intent(in) :: henry_298, d_sol_h, temperature
      real(fp) :: henry

      henry = henry_298 * exp(d_sol_h / R_GAS * (1.0_fp/temperature - 1.0_fp/T_REF))
   end function calculate_henry_constant

