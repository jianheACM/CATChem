   pure function calculate_activity_coefficient(ionic_strength, charge) result(gamma)
      real(fp), intent(in) :: ionic_strength
      integer, intent(in) :: charge
      real(fp) :: gamma

      ! Placeholder - would implement Debye-Hückel or other model
      gamma = 1.0_fp
   end function calculate_activity_coefficient

   !> \brief Partition species between gas and liquid phases
   !! \param[in] total_conc Total concentration
   !! \param[in] henry_const Henry's law constant
   !! \param[in] liquid_water_content Liquid water content [m³/m³]
   !! \param[out] gas_conc Gas-phase concentration
   !! \param[out] liquid_conc Liquid-phase concentration
   pure subroutine partition_gas_liquid(total_conc, henry_const, liquid_water_content, &
                                       gas_conc, liquid_conc)
      real(fp), intent(in) :: total_conc, henry_const, liquid_water_content
      real(fp), intent(out) :: gas_conc, liquid_conc

      real(fp) :: partition_coeff

      partition_coeff = henry_const * liquid_water_content

      gas_conc = total_conc / (1.0_fp + partition_coeff)
      liquid_conc = total_conc * partition_coeff / (1.0_fp + partition_coeff)
   end subroutine partition_gas_liquid

{% elif process_type == 'heterogeneous_chemistry' %}
   !> \brief Calculate uptake coefficient
   !! \param[in] sticking_prob Sticking probability [dimensionless]
   !! \param[in] surface_area Aerosol surface area [m²/m³]
   !! \param[in] mean_speed Mean molecular speed [m/s]
   !! \return Uptake coefficient [s⁻¹]
   pure function calculate_uptake_coefficient(sticking_prob, surface_area, mean_speed) result(uptake)
      real(fp), intent(in) :: sticking_prob, surface_area, mean_speed
      real(fp) :: uptake

      uptake = 0.25_fp * sticking_prob * surface_area * mean_speed
   end function calculate_uptake_coefficient

   !> \brief Calculate aerosol surface area
   !! \param[in] number_conc Number concentration [#/m³]
   !! \param[in] mean_diameter Mean diameter [m]
   !! \return Surface area [m²/m³]
   pure function calculate_surface_area(number_conc, mean_diameter) result(surface_area)
      real(fp), intent(in) :: number_conc, mean_diameter
      real(fp) :: surface_area

      real(fp), parameter :: PI = 3.141592653589793_fp

      surface_area = PI * mean_diameter**2 * number_conc
   end function calculate_surface_area

   !> \brief Apply sticking probability correction
   !! \param[inout] uptake_coeffs Array of uptake coefficients
   !! \param[in] temperature Temperature [K]
   pure subroutine apply_sticking_probability(uptake_coeffs, temperature)
      real(fp), intent(inout) :: uptake_coeffs(:)
      real(fp), intent(in) :: temperature

      real(fp) :: temp_factor
      integer :: i

      ! Simple temperature dependence - would use actual formulations
      temp_factor = T_REF / temperature

      do i = 1, size(uptake_coeffs)
         uptake_coeffs(i) = uptake_coeffs(i) * temp_factor
      end do
   end subroutine apply_sticking_probability
